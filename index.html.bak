<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DubShorts Studio</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --y:#f5e132;--yd:#c8b820;--yg:rgba(245,225,50,0.08);
  --blk:#080808;--s1:#111;--s2:#161616;--s3:#1e1e1e;--s4:#252525;
  --bd:#2a2a2a;--tx:#efefef;--tdim:#888;--tmut:#444;
  --grn:#2ecc71;--red:#ff4136;--pur:#a78bfa;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;}
body{font-family:'DM Sans',sans-serif;background:var(--blk);color:var(--tx);display:flex;overflow:hidden;}
.sidebar{width:195px;height:100vh;background:var(--s1);border-right:1px solid var(--bd);display:flex;flex-direction:column;flex-shrink:0;}
.logo{padding:16px 15px 13px;border-bottom:1px solid var(--bd);}
.logo-mark{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;color:var(--y);}
.logo-sub{font-size:8px;color:var(--tmut);margin-top:2px;letter-spacing:2.5px;text-transform:uppercase;}
.nav{padding:8px 7px;flex:1;overflow-y:auto;}
.nav-sec{margin:12px 0;}
.nav-sec:first-child{margin-top:0;}
.nav-seclbl{font-size:7px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--tmut);padding:0 8px;margin:8px 0 3px;}
.ni{display:flex;align-items:center;gap:8px;padding:7px 9px;border-radius:7px;font-size:12px;font-weight:500;color:var(--tdim);transition:all .15s;border:1px solid transparent;margin-bottom:1px;cursor:pointer;background:none;width:100%;text-align:left;}
.ni:hover{background:var(--s2);color:var(--tx);}
.ni.active{background:var(--yg);border-color:rgba(245,225,50,0.18);color:var(--y);}
.ni .ic{font-size:13px;width:15px;text-align:center;flex-shrink:0;}
.badge{margin-left:auto;font-size:8px;padding:2px 4px;border-radius:3px;font-weight:700;}
.badge.live{background:rgba(46,204,113,.1);color:var(--grn);}
.badge.new{background:rgba(245,225,50,.1);color:var(--yd);}
.badge.soon{background:rgba(255,65,54,.1);color:var(--red);}
.sf{padding:10px 13px;border-top:1px solid var(--bd);}
.credits-display{font-size:11px;color:var(--y);font-weight:700;font-family:'Space Mono',monospace;}
.main{flex:1;display:flex;flex-direction:column;min-width:0;height:100vh;overflow:hidden;min-height:0;}
.topbar{padding:11px 20px;border-bottom:1px solid var(--bd);display:flex;align-items:center;gap:6px;flex-shrink:0;}
.pg-title{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;color:var(--y);}
.tab-panel{display:none;flex:1;overflow:hidden;}
.tab-panel.active{display:flex;height:100%;min-height:0;}
.workspace{flex:1;display:flex;overflow:hidden;height:100%;min-height:0;}
.left-panel{width:400px;flex-shrink:0;border-right:1px solid var(--bd);overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:11px;}
.right-panel{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;background:var(--blk);gap:10px;padding:20px;overflow-y:auto;}
.sec-lbl{font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--tdim);margin-bottom:6px;}
.upload-zone{border:1.5px dashed var(--bd);border-radius:11px;padding:18px 16px;text-align:center;cursor:pointer;position:relative;transition:all .2s;background:var(--s1);}
.upload-zone:hover{border-color:var(--yd);background:var(--s2);}
.upload-zone.has-file{border-color:rgba(245,225,50,.35);border-style:solid;background:rgba(245,225,50,.02);}
.upload-zone.drag{border-color:var(--y);background:var(--yg);}
.up-icon{font-size:22px;display:block;margin-bottom:5px;}
.up-title{font-size:13px;font-weight:600;margin-bottom:2px;}
.up-hint{font-size:11px;color:var(--tmut);}
.up-name{font-size:10px;color:var(--y);font-weight:600;margin-top:4px;word-break:break-all;}
.text-input{background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:10px 12px;color:var(--tx);font-size:12px;font-family:'DM Sans',sans-serif;width:100%;outline:none;transition:border-color .15s;}
.text-input:focus{border-color:rgba(245,225,50,.4);}
.text-input::placeholder{color:var(--tmut);}
.textarea{background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:10px 12px;color:var(--tx);font-size:12px;font-family:'DM Sans',sans-serif;width:100%;outline:none;resize:vertical;min-height:80px;transition:border-color .15s;}
.textarea:focus{border-color:rgba(245,225,50,.4);}
.textarea::placeholder{color:var(--tmut);}
.btn{padding:12px;background:var(--y);color:var(--blk);border:none;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer;font-family:'Space Mono',monospace;transition:all .2s;width:100%;letter-spacing:.4px;}
.btn:hover{background:#ffe600;box-shadow:0 4px 20px rgba(245,225,50,.2);}
.btn:disabled{background:var(--s4);color:var(--tmut);cursor:not-allowed;box-shadow:none;}
.select{background:var(--s3);border:1px solid var(--bd);color:var(--tx);padding:10px 12px;border-radius:8px;font-size:12px;font-family:'DM Sans',sans-serif;outline:none;cursor:pointer;width:100%;transition:all .15s;}
.select:hover{border-color:rgba(245,225,50,.3);}
.select:focus{border-color:rgba(245,225,50,.5);}
.card{background:var(--s2);border:1px solid var(--bd);border-radius:10px;overflow:hidden;}
.card-hd{padding:9px 12px;border-bottom:1px solid var(--bd);font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--y);}
.card-body{padding:12px;display:flex;flex-direction:column;gap:10px;}
.setting-row{display:flex;flex-direction:column;gap:5px;}
.setting-label{font-size:11px;font-weight:600;color:var(--tdim);}
.setting-value{font-size:10px;color:var(--y);font-family:'Space Mono',monospace;}
.toggle-row{display:flex;align-items:center;justify-content:space-between;}
.toggle-wrap{display:flex;align-items:center;gap:8px;}
.toggle{position:relative;width:34px;height:18px;}
.toggle input{opacity:0;width:0;height:0;}
.toggle-slider{position:absolute;inset:0;background:var(--s4);border-radius:18px;transition:.2s;cursor:pointer;border:1px solid var(--bd);}
.toggle-slider:before{content:'';position:absolute;left:2px;top:50%;transform:translateY(-50%);width:12px;height:12px;background:var(--tdim);border-radius:50%;transition:.2s;}
.toggle input:checked + .toggle-slider{background:rgba(245,225,50,.15);border-color:rgba(245,225,50,.4);}
.toggle input:checked + .toggle-slider:before{transform:translateX(16px) translateY(-50%);background:var(--y);}
.toggle-lbl{font-size:11px;font-weight:600;color:var(--tdim);}
.toggle-note{font-size:9px;color:var(--tmut);}
.slider-row{display:flex;flex-direction:column;gap:4px;}
.slider{width:100%;cursor:pointer;}
.slider-labels{display:flex;justify-content:space-between;font-size:9px;color:var(--tdim);}
.char-count{font-size:9px;color:var(--tmut);margin-top:4px;}
.prog-wrap{display:none;}
.prog-wrap.vis{display:block;}
.prog-lbl{font-size:10px;color:var(--tdim);font-family:'Space Mono',monospace;margin-bottom:4px;display:flex;justify-content:space-between;}
.prog-track{background:var(--s4);border-radius:4px;height:4px;overflow:hidden;border:1px solid var(--bd);}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--y),#ffe600);border-radius:4px;width:0%;transition:width .35s ease;}
.err-box{background:rgba(255,65,54,.04);border:1px solid rgba(255,65,54,.14);border-radius:9px;padding:11px;display:none;}
.err-box.vis{display:block;}
.err-ttl{font-size:10px;font-weight:700;font-family:'Space Mono',monospace;color:var(--red);margin-bottom:4px;}
.err-msg{color:#ff7070;font-size:11px;line-height:1.5;}
.phone-wrap{height:calc(100vh - 44px - 80px);max-height:560px;aspect-ratio:9/16;max-width:315px;position:relative;border-radius:14px;overflow:hidden;background:#000;border:1.5px solid var(--bd);box-shadow:0 16px 48px rgba(0,0,0,.7);flex-shrink:0;}
.ph-empty{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--tdim);}
.ph-empty span{font-size:28px;}
.ph-empty p{font-size:11px;}
.ph-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:none;}
.prev-lbl{font-size:9px;color:var(--tdim);font-family:'Space Mono',monospace;letter-spacing:1px;}
.result-btns{width:100%;max-width:315px;display:none;flex-direction:column;gap:7px;}
.result-btns.vis{display:flex;}
.dl-btn{display:block;width:100%;padding:9px;background:var(--grn);color:#000;border:none;border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Space Mono',monospace;text-align:center;text-decoration:none;transition:all .2s;}
.dl-btn:hover{background:#27ae60;}
.info-box{background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:11px 13px;font-size:11px;color:var(--tdim);line-height:1.8;}
.info-box b{color:var(--tx);}

/* Voice Gen specific */
.voice-item{display:flex;align-items:center;justify-content:space-between;padding:9px 11px;background:var(--s3);border:1px solid var(--bd);border-radius:8px;margin-bottom:6px;cursor:pointer;transition:all .15s;}
.voice-item:hover{border-color:rgba(245,225,50,.2);background:var(--s4);}
.voice-item.selected{border-color:rgba(245,225,50,.4);background:rgba(245,225,50,.04);}
.voice-item-name{font-size:12px;font-weight:600;color:var(--tx);}
.voice-item-tag{font-size:9px;color:var(--tdim);margin-top:2px;}
.voice-del{background:none;border:none;color:var(--tmut);cursor:pointer;font-size:14px;padding:2px 6px;border-radius:4px;transition:all .15s;}
.voice-del:hover{color:var(--red);background:rgba(255,65,54,.08);}
.add-voice-btn{display:flex;align-items:center;justify-content:center;gap:6px;width:100%;padding:9px;background:var(--s3);border:1.5px dashed var(--bd);border-radius:8px;color:var(--tdim);font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;}
.add-voice-btn:hover{border-color:rgba(245,225,50,.3);color:var(--y);background:var(--yg);}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:100;display:flex;align-items:center;justify-content:center;}
.modal{background:var(--s2);border:1px solid var(--bd);border-radius:14px;padding:20px;width:340px;display:flex;flex-direction:column;gap:12px;}
.modal-title{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;color:var(--y);}
.modal-btns{display:flex;gap:8px;}
.modal-btn-cancel{flex:1;padding:10px;background:var(--s4);border:1px solid var(--bd);border-radius:8px;color:var(--tdim);font-size:12px;font-weight:700;font-family:'Space Mono',monospace;cursor:pointer;}
.modal-btn-save{flex:1;padding:10px;background:var(--y);border:none;border-radius:8px;color:var(--blk);font-size:12px;font-weight:700;font-family:'Space Mono',monospace;cursor:pointer;}
</style>
</head>
<body>

<aside class="sidebar">
  <div class="logo">
    <div class="logo-mark">DubShorts</div>
    <div class="logo-sub">AI Studio v3</div>
  </div>
  <nav class="nav">
    <div class="nav-sec">
      <div class="nav-seclbl">Generation</div>
      <button class="ni active" id="nav-vidgen" onclick="switchTab('vidgen')"><span class="ic">✨</span>AI Video Gen<span class="badge live">LIVE</span></button>
      <button class="ni" id="nav-imggen" onclick="switchTab('imggen')"><span class="ic">🎨</span>AI Image Gen<span class="badge live">LIVE</span></button>
    </div>
    <div class="nav-sec">
      <div class="nav-seclbl">Utilities</div>
      <button class="ni" id="nav-voicegen" onclick="switchTab('voicegen')"><span class="ic">🔊</span>Voice Gen<span class="badge live">LIVE</span></button>
      <button class="ni" id="nav-deadspace" onclick="switchTab('deadspace')"><span class="ic">🎬</span>Dead Space Remover<span class="badge live">LIVE</span></button>
    </div>
    <div class="nav-sec">
      <div class="nav-seclbl">Content</div>
      <button class="ni" id="nav-scraper" onclick="switchTab('scraper')"><span class="ic">🎥</span>YT Scraper<span class="badge live">LIVE</span></button>
      <button class="ni" id="nav-repurpose" onclick="switchTab('repurpose')"><span class="ic">🔄</span>Repurpose<span class="badge soon">SOON</span></button>
      <button class="ni" id="nav-automation" onclick="switchTab('automation')"><span class="ic">⚡</span>Automation<span class="badge new">NEW</span></button>
    </div>
  </nav>
  <div class="sf">
    <div class="credits-display">💳 <span id="creditsDisplay">500 Credits</span></div>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <span class="pg-title" id="topTitle">AI Video Gen</span>
    <span style="color:var(--tdim);margin-left:auto;font-size:11px;font-family:'Space Mono',monospace;">1 credit = $0.01</span>
  </div>

  <!-- ══ AI VIDEO GEN ══ -->
  <div class="tab-panel active" id="tab-vidgen">
    <div class="workspace">
      <div class="left-panel">
        <div class="upload-zone" id="imgDrop" onclick="document.getElementById('imgInput').click()">
          <input type="file" id="imgInput" accept="image/*" style="display:none">
          <span class="up-icon">🖼</span>
          <div class="up-title" id="imgDropTitle">Drop image here <span style="font-size:10px;color:var(--tmut);font-weight:400;">(optional)</span></div>
          <div class="up-hint">PNG · JPG · WEBP</div>
          <div class="up-name" id="imgFnm"></div>
        </div>
        <div>
          <div class="sec-lbl">Prompt</div>
          <textarea class="textarea" id="aivgPrompt" rows="3" placeholder="Describe the motion…"></textarea>
        </div>
        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Model</label>
              <select class="select" id="vidModel" onchange="onModelChange()">
                <option value="veo3-lite" selected>Veo 3.1 Lite — 20 credits</option>
                <option value="sora2">Sora 2 — 20 credits</option>
                <option value="grok">Grok Imagine — 30cr (Kie.ai)</option>
              </select>
            </div>
            <div class="setting-row" id="durationRow">
              <label class="setting-label">Duration</label>
              <select class="select" id="vidDuration"></select>
            </div>
            <div class="setting-row" id="aspectRow">
              <label class="setting-label">Aspect Ratio</label>
              <select class="select" id="vidAspect"></select>
            </div>
            <div class="setting-row" id="qualityRow" style="display:none;">
              <label class="setting-label">Quality</label>
              <select class="select" id="vidQuality" onchange="onQualityChange()"></select>
            </div>
            <div class="setting-row">
              <label class="setting-label">Cost</label>
              <div class="setting-value" id="vidCost">20 credits</div>
            </div>
          </div>
        </div>
        <button class="btn" id="vidBtn" onclick="startVidGen()">⚡ Generate Video</button>
        <div class="prog-wrap" id="vidProg">
          <div class="prog-lbl"><span id="vpLbl">Submitting job…</span><span id="vpPct">0%</span></div>
          <div class="prog-track"><div class="prog-fill" id="vpFill"></div></div>
        </div>
        <div class="err-box" id="vidErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="vidErrMsg"></div></div>
      </div>
      <div class="right-panel">
        <div class="phone-wrap">
          <div class="ph-empty" id="vidEmpty"><span>📱</span><p>Generate a video to preview</p></div>
          <video class="ph-video" id="vidVideo" controls playsinline loop></video>
        </div>
        <div class="prev-lbl">PREVIEW</div>
        <div class="result-btns" id="vidResultBtns">
          <a class="dl-btn" id="vidDlBtn" href="#" download="video.mp4">⬇ Download Video</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ AI IMAGE GEN ══ -->
  <div class="tab-panel" id="tab-imggen">
    <div class="workspace">
      <div class="left-panel">
        <div class="upload-zone" id="refImgDrop" onclick="document.getElementById('refImgInput').click()">
          <input type="file" id="refImgInput" accept="image/*" style="display:none">
          <span class="up-icon">📷</span>
          <div class="up-title">Reference Image <span style="font-size:10px;color:var(--tmut);font-weight:400;">(optional)</span></div>
          <div class="up-hint">PNG · JPG · WEBP</div>
          <div class="up-name" id="refImgFnm"></div>
        </div>
        <div>
          <div class="sec-lbl">Prompt</div>
          <textarea class="textarea" id="imgPrompt" rows="4" placeholder="Describe the image you want to generate…"></textarea>
        </div>
        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Model</label>
              <select class="select" id="imgModel" onchange="onImgModelChange()">
                <option value="nano-banana-pro" selected>Nano Banana Pro</option>
                <option value="nano-banana-2">Nano Banana 2</option>
              </select>
            </div>
            <div class="setting-row">
              <label class="setting-label">Aspect Ratio</label>
              <select class="select" id="imgAspect" onchange="onImgAspectChange()">
                <option value="9:16" selected>9:16 (Portrait)</option>
                <option value="16:9">16:9 (Landscape)</option>
                <option value="1:1">1:1 (Square)</option>
              </select>
            </div>


            <div class="setting-row">
              <label class="setting-label">Cost</label>
              <div class="setting-value" id="imgCost">18 credits</div>
            </div>
          </div>
        </div>
        <button class="btn" id="imgBtn" onclick="startImgGen()">🎨 Generate Image</button>
        <div class="prog-wrap" id="imgProg">
          <div class="prog-lbl"><span id="ipLbl">Generating...</span><span id="ipPct">0%</span></div>
          <div class="prog-track"><div class="prog-fill" id="ipFill"></div></div>
        </div>
        <div class="err-box" id="imgErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="imgErrMsg"></div></div>
      </div>
      <div class="right-panel">
        <div id="imgPreviewWrap" style="width:100%;max-width:360px;border-radius:12px;background:var(--s3);border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;overflow:hidden;aspect-ratio:9/16;">
          <img id="genImgPrev" style="width:100%;height:100%;object-fit:cover;display:none;" alt="Generated image">
          <div id="imgEmpty" style="text-align:center;color:var(--tdim);padding:20px;">
            <span style="font-size:32px;display:block;margin-bottom:8px;">🎨</span>
            <p style="font-size:11px;">Your generated image will appear here</p>
          </div>
        </div>
        <div class="prev-lbl">PREVIEW</div>
        <a class="dl-btn" id="dlImgBtn" href="#" download="image.png" style="display:none;width:100%;max-width:360px;">⬇ Download Image</a>
      </div>
    </div>
  </div>

  <!-- ══ VOICE GEN ══ -->
  <div class="tab-panel" id="tab-voicegen">
    <div class="workspace" style="height:100%;overflow:hidden;">

      <!-- LEFT — voice selection + settings, scrollable -->
      <div class="left-panel" style="overflow-y:auto;height:100%;max-height:100%;">

        <!-- Voice selection -->
        <div class="card">
          <div class="card-hd">Voice</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Selected Voice</label>
              <div style="display:flex;gap:6px;align-items:center;">
                <select class="select" id="voiceDropdown" onchange="onVoiceDropdownChange()" style="flex:1;"></select>
                <button id="deleteVoiceBtn" onclick="deleteSelectedVoice()" style="background:var(--s4);border:1px solid var(--bd);border-radius:7px;color:var(--tmut);font-size:12px;padding:9px 10px;cursor:pointer;flex-shrink:0;display:none;" title="Delete voice">✕</button>
              </div>
            </div>
            <button class="add-voice-btn" onclick="openAddVoiceModal()">＋ Add Voice</button>
          </div>
        </div>

        <!-- Settings -->
        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="slider-row">
              <div class="setting-label">Speed</div>
              <div class="slider-labels"><span>Slower</span><span id="speedVal">1.0</span><span>Faster</span></div>
              <input type="range" class="slider" id="speedSlider" min="0.7" max="1.2" step="0.05" value="1.0" oninput="updateSpeedVal()">
            </div>
            <div class="slider-row">
              <div class="setting-label">Stability</div>
              <div class="slider-labels"><span>Variable</span><span id="stabilityVal">50%</span><span>Stable</span></div>
              <input type="range" class="slider" id="stabilitySlider" min="0" max="100" value="50" oninput="updateStabilityVal()">
            </div>
            <div class="slider-row">
              <div class="setting-label">Similarity</div>
              <div class="slider-labels"><span>Low</span><span id="similarityVal">75%</span><span>High</span></div>
              <input type="range" class="slider" id="similaritySlider" min="0" max="100" value="75" oninput="updateSimilarityVal()">
            </div>
            <div class="slider-row">
              <div class="setting-label">Exaggeration</div>
              <div class="slider-labels"><span>Neutral</span><span id="exagVal">0.5</span><span>Expressive</span></div>
              <input type="range" class="slider" id="exagSlider" min="0" max="1" step="0.05" value="0.5" oninput="updateExagVal()">
            </div>
          </div>
        </div>

        <button class="btn" id="voiceBtn" onclick="startVoiceGen()">🔊 Generate Speech</button>
        <div class="prog-wrap" id="voiceProg">
          <div class="prog-lbl"><span id="voiceProgLbl">Generating...</span><span id="voiceProgPct">0%</span></div>
          <div class="prog-track"><div class="prog-fill" id="vrFill"></div></div>
        </div>
        <div class="err-box" id="voiceErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="voiceErrMsg"></div></div>
      </div>

      <!-- RIGHT — script + output list -->
      <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;height:100%;min-height:0;">

        <!-- Script area at top -->
        <div style="padding:16px;border-bottom:1px solid var(--bd);flex-shrink:0;">
          <div class="sec-lbl">Script</div>
          <textarea class="textarea" id="voiceScript" rows="5" placeholder="Enter your voiceover script…" oninput="updateCharCount()" style="width:100%;"></textarea>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:6px;">
            <div class="char-count"><span id="charCount">0</span> characters</div>
          </div>
        </div>

        <!-- Saved outputs list -->
        <div style="flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px;">
          <div class="sec-lbl">Generated Voiceovers</div>
          <div id="voiceOutputList">
            <div id="voiceOutputEmpty" style="text-align:center;padding:40px 20px;color:var(--tmut);font-size:12px;">
              <span style="font-size:28px;display:block;margin-bottom:8px;">🔊</span>
              Generated voiceovers will appear here
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ══ DEAD SPACE REMOVER ══ -->
  <div class="tab-panel" id="tab-deadspace">
    <div class="workspace">
      <div class="left-panel">
        <div class="upload-zone" id="deadspaceZone" onclick="document.getElementById('deadspaceInput').click()">
          <input type="file" id="deadspaceInput" accept="video/*,audio/*" style="display:none">
          <span class="up-icon">🎬</span>
          <div class="up-title">Drop video or audio here</div>
          <div class="up-hint">MP4 · MOV · WAV · MP3</div>
          <div class="up-name" id="deadspaceFnm"></div>
        </div>
        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="setting-row">
              <div class="setting-label">Strength</div>
              <div style="display:flex;gap:6px;margin-top:4px;">
                <button onclick="setDsStrength(this,'light')" class="ds-strength-btn" style="flex:1;padding:8px;background:var(--s3);border:1px solid var(--bd);border-radius:7px;color:var(--tdim);font-size:11px;font-weight:700;cursor:pointer;">🟢 Light</button>
                <button onclick="setDsStrength(this,'medium')" class="ds-strength-btn active-strength" style="flex:1;padding:8px;background:var(--yg);border:1px solid rgba(245,225,50,.4);border-radius:7px;color:var(--y);font-size:11px;font-weight:700;cursor:pointer;">🟡 Medium</button>
                <button onclick="setDsStrength(this,'strong')" class="ds-strength-btn" style="flex:1;padding:8px;background:var(--s3);border:1px solid var(--bd);border-radius:7px;color:var(--tdim);font-size:11px;font-weight:700;cursor:pointer;">🔴 Strong</button>
              </div>
              <input type="hidden" id="dsStrength" value="medium">
              <div style="font-size:9px;color:var(--tmut);margin-top:4px;">Light = remove long pauses · Medium = balanced · Strong = remove all gaps</div>
            </div>
            <div class="setting-row">
              <label class="setting-label">Cost</label>
              <div class="setting-value">5 credits</div>
            </div>
          </div>
        </div>
        <button class="btn" id="dsBtn" onclick="startDeadspace()" disabled>🎬 Remove Dead Space</button>
      </div>
      <div class="right-panel">
        <div class="phone-wrap">
          <div class="ph-empty" id="dsEmpty"><span>📁</span><p>Upload a video or audio file</p></div>
          <video id="dsVid" controls style="display:none;position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"></video>
        </div>
        <div class="prev-lbl">TRIMMED</div>
        <div id="dsDlWrap" style="display:none;width:100%;max-width:315px;">
          <a id="dsDlBtn" class="dl-btn" download="trimmed.mp4">⬇ Download Trimmed Video</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ YT SCRAPER ══ -->
  <div class="tab-panel" id="tab-scraper">
    <div class="workspace">
      <div class="left-panel">
        <div>
          <div class="sec-lbl">Channel Link</div>
          <input type="text" class="text-input" id="ytChannelUrl" placeholder="https://youtube.com/@channelname">
        </div>
        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Number of Videos</label>
              <select class="select" id="ytCount">
                <option value="10">10 videos</option>
                <option value="25" selected>25 videos</option>
                <option value="50">50 videos</option>
                <option value="100">100 videos</option>
              </select>
            </div>
            <div class="setting-row">
              <label class="setting-label">Sort By</label>
              <select class="select" id="ytSort">
                <option value="newest" selected>📅 Newest</option>
                <option value="popular">🔥 Most Popular</option>
                <option value="trending">📈 Trending (recent + viral)</option>
              </select>
            </div>
            <div class="setting-row">
              <label class="setting-label">Cost</label>
              <div class="setting-value">2 credits</div>
            </div>
          </div>
        </div>
        <button class="btn" id="scrapBtn" onclick="startScrape()">🎥 Scrape Channel</button>
        <div class="err-box" id="scrapErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="scrapErrMsg"></div></div>
      </div>
      <div class="right-panel">
        <div style="width:100%;max-width:400px;background:var(--s2);border:1px solid var(--bd);border-radius:12px;overflow:hidden;">
          <div style="padding:14px;border-bottom:1px solid var(--bd);font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--y);">Scraped Videos</div>
          <div id="scrapList" style="max-height:300px;overflow-y:auto;padding:10px;">
            <div style="text-align:center;padding:30px;color:var(--tdim);font-size:11px;">No data yet</div>
          </div>
        </div>
        <button id="scrapDlBtn" onclick="exportScrapeJSON()" style="display:none;width:100%;max-width:400px;margin-top:8px;padding:10px;background:var(--grn);color:#000;border:none;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Space Mono',monospace;">⬇ Download Results (JSON)</button>
      </div>
    </div>
  </div>

  <!-- ══ REPURPOSE ══ -->
  <div class="tab-panel" id="tab-repurpose">
    <div class="workspace">
      <div class="left-panel">
        <div>
          <div class="sec-lbl">YouTube Channel Link</div>
          <input type="text" class="text-input" id="repYtChannel" placeholder="https://youtube.com/@yourchannel">
        </div>
        <div class="card">
          <div class="card-hd">Platforms</div>
          <div class="card-body">
            <label style="display:flex;gap:8px;align-items:center;font-size:12px;cursor:pointer;margin-bottom:8px;"><input type="checkbox" id="repTiktok" checked> TikTok</label>
            <label style="display:flex;gap:8px;align-items:center;font-size:12px;cursor:pointer;"><input type="checkbox" id="repInstagram" checked> Instagram</label>
          </div>
        </div>
        <div class="card">
          <div class="card-hd">Account Connections</div>
          <div class="card-body">
            <div id="tiktokConnect" style="display:none;">
              <button class="btn" style="padding:10px;font-size:11px;margin-bottom:8px;" onclick="connectTiktok()">Connect TikTok Account</button>
              <div id="tiktokStatus" style="font-size:10px;color:var(--tdim);text-align:center;">Not connected</div>
            </div>
            <div id="instagramConnect" style="display:none;">
              <button class="btn" style="padding:10px;font-size:11px;" onclick="connectInstagram()">Connect Instagram Account</button>
              <div id="instagramStatus" style="font-size:10px;color:var(--tdim);text-align:center;">Not connected</div>
            </div>
          </div>
        </div>
        <button class="btn" onclick="startRepurpose()">🔄 Enable Auto-Repurpose</button>
      </div>
      <div class="right-panel">
        <div style="width:100%;max-width:400px;text-align:center;padding:40px 20px;color:var(--tdim);">
          <span style="font-size:32px;display:block;margin-bottom:10px;">🔄</span>
          <p style="font-size:12px;">Connect your accounts and enable auto-repurposing</p>
          <div id="repStatus" style="margin-top:20px;font-size:11px;color:var(--tmut);">Status: Inactive</div>
        </div>
      </div>
    </div>
  </div>

<!-- ══ AUTOMATION TAB — paste this inside the .main div, after the YT SCRAPER tab panel ══ -->

<!-- NAV BUTTON — add to sidebar nav under Content section -->
<!--
<button class="ni" id="nav-automation" onclick="switchTab('automation')"><span class="ic">⚡</span>Automation<span class="badge new">NEW</span></button>
-->

<!-- TAB PANEL -->
<div class="tab-panel" id="tab-automation">
  <div style="display:flex;height:100%;overflow:hidden;">

    <!-- STEPS SIDEBAR -->
    <div style="width:200px;flex-shrink:0;border-right:1px solid var(--bd);background:var(--s1);padding:12px 8px;display:flex;flex-direction:column;gap:4px;overflow-y:auto;">
      <div style="font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--tmut);padding:0 8px;margin-bottom:8px;">Pipeline</div>
      <button class="auto-step-btn active" onclick="gotoStep(1)" id="step-btn-1">
        <span class="step-num">1</span><span class="step-label">Ideation</span><span class="step-check" id="step-check-1"></span>
      </button>
      <button class="auto-step-btn" onclick="gotoStep(2)" id="step-btn-2">
        <span class="step-num">2</span><span class="step-label">Script</span><span class="step-check" id="step-check-2"></span>
      </button>
      <button class="auto-step-btn" onclick="gotoStep(3)" id="step-btn-3">
        <span class="step-num">3</span><span class="step-label">Reference Video</span><span class="step-check" id="step-check-3"></span>
      </button>
      <button class="auto-step-btn" onclick="gotoStep(4)" id="step-btn-4">
        <span class="step-num">4</span><span class="step-label">Reference Image</span><span class="step-check" id="step-check-4"></span>
      </button>
      <button class="auto-step-btn" onclick="gotoStep(5)" id="step-btn-5">
        <span class="step-num">5</span><span class="step-label">Scenes</span><span class="step-check" id="step-check-5"></span>
      </button>
      <button class="auto-step-btn" onclick="gotoStep(6)" id="step-btn-6">
        <span class="step-num">6</span><span class="step-label">Scene Images</span><span class="step-check" id="step-check-6"></span>
      </button>
      <button class="auto-step-btn" onclick="gotoStep(7)" id="step-btn-7">
        <span class="step-num">7</span><span class="step-label">Generate Clips</span><span class="step-check" id="step-check-7"></span>
      </button>

      <!-- Progress -->
      <div style="margin-top:auto;padding:10px 8px 0;">
        <div style="font-size:9px;color:var(--tmut);margin-bottom:4px;">Progress</div>
        <div style="background:var(--s4);border-radius:4px;height:4px;overflow:hidden;">
          <div id="pipelineProgress" style="height:100%;background:linear-gradient(90deg,var(--y),#ffe600);border-radius:4px;width:0%;transition:width .4s ease;"></div>
        </div>
        <div style="font-size:9px;color:var(--tdim);margin-top:4px;font-family:'Space Mono',monospace;" id="progressLabel">0 / 7 steps</div>
      </div>
    </div>

    <!-- MAIN CONTENT AREA -->
    <div style="flex:1;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:16px;">

      <!-- ══ STEP 1: IDEATION ══ -->
      <div class="auto-step-panel active" id="auto-step-1">
        <div class="auto-step-header">
          <div class="auto-step-title">💡 Step 1 — Ideation</div>
          <div class="auto-step-desc">Paste your competitor's scraped data or type your own idea. Claude will suggest 5 viral content ideas.</div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div>
            <div class="sec-lbl" style="margin-bottom:6px;">Competitor Data (JSON from Scraper)</div>
            <textarea class="textarea" id="autoCompetitorData" rows="8" placeholder='Paste scraped channel JSON here, or leave empty to type your own idea…'></textarea>
            <div style="font-size:9px;color:var(--tmut);margin-top:4px;">Tip: Use the YT Scraper tab to get channel data, then paste it here</div>
          </div>
          <div>
            <div class="sec-lbl" style="margin-bottom:6px;">Your Niche / Topic (optional)</div>
            <textarea class="textarea" id="autoNiche" rows="4" placeholder="e.g. dark psychology, court cases, finance tips for Gen Z…"></textarea>
            <div style="margin-top:8px;">
              <div class="sec-lbl" style="margin-bottom:6px;">Or Type Your Own Idea</div>
              <textarea class="textarea" id="autoOwnIdea" rows="3" placeholder="Skip AI suggestions and use your own concept…"></textarea>
            </div>
          </div>
        </div>

        <button class="btn" id="ideationBtn" onclick="runIdeation()" style="max-width:300px;">💡 Generate 5 Viral Ideas</button>

        <div class="auto-loading" id="ideationLoading">
          <div class="auto-spinner"></div>
          <span>Claude is analysing your competitor data…</span>
        </div>

        <!-- Ideas output -->
        <div id="ideasOutput" style="display:none;">
          <div class="sec-lbl" style="margin-bottom:8px;">Choose Your Idea</div>
          <div id="ideasList" style="display:flex;flex-direction:column;gap:8px;"></div>
          <div style="margin-top:12px;display:flex;gap:8px;">
            <button class="btn" onclick="confirmIdea()" style="max-width:200px;">✓ Use Selected Idea</button>
            <button onclick="runIdeation()" style="padding:12px 16px;background:var(--s3);border:1px solid var(--bd);border-radius:9px;color:var(--tdim);font-size:12px;font-weight:700;cursor:pointer;font-family:'Space Mono',monospace;">↺ Regenerate</button>
          </div>
        </div>
      </div>

      <!-- ══ STEP 2: SCRIPT ══ -->
      <div class="auto-step-panel" id="auto-step-2">
        <div class="auto-step-header">
          <div class="auto-step-title">📝 Step 2 — Script</div>
          <div class="auto-step-desc">Claude generates a viral script based on your idea, matched to the length of your competitors' best videos.</div>
        </div>

        <div style="background:var(--s2);border:1px solid var(--bd);border-radius:10px;padding:12px;margin-bottom:12px;">
          <div style="font-size:10px;color:var(--tdim);margin-bottom:4px;">Selected Idea</div>
          <div id="selectedIdeaDisplay" style="font-size:13px;font-weight:600;color:var(--y);"></div>
        </div>

        <div>
          <div class="sec-lbl" style="margin-bottom:6px;">Additional Direction (optional)</div>
          <textarea class="textarea" id="scriptPrompt" rows="2" placeholder="e.g. Make it more emotional, add a shocking statistic at the start, keep it under 60 seconds…"></textarea>
        </div>

        <div style="display:flex;gap:8px;">
          <button class="btn" id="scriptBtn" onclick="generateScript()" style="max-width:250px;">✍️ Generate Script</button>
        </div>

        <div class="auto-loading" id="scriptLoading">
          <div class="auto-spinner"></div>
          <span>Writing your viral script…</span>
        </div>

        <div id="scriptOutput" style="display:none;">
          <div class="sec-lbl" style="margin-bottom:6px;">Your Script <span style="color:var(--tmut);font-weight:400;">(editable)</span></div>
          <textarea class="textarea" id="finalScript" rows="12" placeholder="Script will appear here…"></textarea>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:6px;">
            <div style="font-size:9px;color:var(--tmut);font-family:'Space Mono',monospace;" id="scriptWordCount"></div>
            <div style="display:flex;gap:8px;">
              <button onclick="generateScript()" style="padding:8px 12px;background:var(--s3);border:1px solid var(--bd);border-radius:7px;color:var(--tdim);font-size:11px;font-weight:700;cursor:pointer;font-family:'Space Mono',monospace;">↺ Regenerate</button>
              <button class="btn" onclick="confirmScript()" style="max-width:160px;padding:8px 12px;">✓ Use Script</button>
            </div>
          </div>
        </div>
      </div>

      <!-- ══ STEP 3: REFERENCE VIDEO ══ -->
      <div class="auto-step-panel" id="auto-step-3">
        <div class="auto-step-header">
          <div class="auto-step-title">🎬 Step 3 — Reference Video</div>
          <div class="auto-step-desc">Add a reference video link. AI will analyse the scene structure and pacing to match your video's style.</div>
        </div>

        <div>
          <div class="sec-lbl" style="margin-bottom:6px;">Reference Video URL</div>
          <div style="display:flex;gap:8px;">
            <input type="text" class="text-input" id="refVideoUrl" placeholder="https://www.youtube.com/watch?v=... or TikTok URL" style="flex:1;">
            <button onclick="analyseRefVideo()" style="padding:10px 16px;background:var(--s3);border:1px solid var(--bd);border-radius:9px;color:var(--tdim);font-size:12px;font-weight:700;cursor:pointer;font-family:'Space Mono',monospace;white-space:nowrap;">🔍 Analyse</button>
          </div>
        </div>

        <div class="auto-loading" id="refVideoLoading">
          <div class="auto-spinner"></div>
          <span>Analysing video structure and scenes…</span>
        </div>

        <div id="refVideoOutput" style="display:none;">
          <div class="sec-lbl" style="margin-bottom:8px;">Detected Scene Structure</div>
          <div id="refVideoScenes" style="display:flex;flex-direction:column;gap:6px;"></div>
          <button class="btn" onclick="confirmRefVideo()" style="max-width:200px;margin-top:12px;">✓ Use This Structure</button>
        </div>

        <button onclick="skipStep(3)" style="margin-top:8px;padding:8px 12px;background:none;border:1px solid var(--bd);border-radius:7px;color:var(--tmut);font-size:11px;cursor:pointer;">Skip this step →</button>
      </div>

      <!-- ══ STEP 4: REFERENCE IMAGE ══ -->
      <div class="auto-step-panel" id="auto-step-4">
        <div class="auto-step-header">
          <div class="auto-step-title">🖼 Step 4 — Skeleton Reference Image</div>
          <div class="auto-step-desc">Upload your skeleton/character reference image. This will be used to maintain consistent character appearance across all scenes.</div>
        </div>

        <div class="upload-zone" id="refImgDropAuto" onclick="document.getElementById('refImgInputAuto').click()" style="max-width:400px;">
          <input type="file" id="refImgInputAuto" accept="image/*" style="display:none">
          <span class="up-icon">🦴</span>
          <div class="up-title">Drop skeleton reference image</div>
          <div class="up-hint">PNG · JPG · WEBP</div>
          <div class="up-name" id="refImgAutoFnm"></div>
        </div>

        <div id="refImgAutoPreview" style="display:none;margin-top:12px;">
          <img id="refImgAutoImg" style="max-width:200px;max-height:200px;border-radius:8px;border:1px solid var(--bd);">
        </div>

        <div style="display:flex;gap:8px;margin-top:12px;">
          <button class="btn" onclick="confirmRefImg()" id="confirmRefImgBtn" style="max-width:200px;" disabled>✓ Use This Image</button>
          <button onclick="skipStep(4)" style="padding:8px 12px;background:none;border:1px solid var(--bd);border-radius:7px;color:var(--tmut);font-size:11px;cursor:pointer;">Skip this step →</button>
        </div>
      </div>

      <!-- ══ STEP 5: SCENES ══ -->
      <div class="auto-step-panel" id="auto-step-5">
        <div class="auto-step-header">
          <div class="auto-step-title">🎭 Step 5 — Scenes</div>
          <div class="auto-step-desc">Claude splits your script into scenes and writes optimised Kie.ai image prompts for each one. Edit, add or delete as needed.</div>
        </div>

        <div style="display:flex;gap:8px;margin-bottom:12px;">
          <button class="btn" id="scenesBtn" onclick="generateScenes()" style="max-width:250px;">🎭 Auto-Split into Scenes</button>
        </div>

        <div class="auto-loading" id="scenesLoading">
          <div class="auto-spinner"></div>
          <span>Claude is splitting your script into scenes…</span>
        </div>

        <div id="scenesOutput" style="display:none;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
            <div class="sec-lbl">Scenes <span id="sceneCount" style="color:var(--y);"></span></div>
            <button onclick="addScene()" style="padding:6px 12px;background:var(--s3);border:1px solid var(--bd);border-radius:7px;color:var(--tdim);font-size:11px;font-weight:700;cursor:pointer;font-family:'Space Mono',monospace;">+ Add Scene</button>
          </div>
          <div id="scenesList" style="display:flex;flex-direction:column;gap:10px;"></div>
          <button class="btn" onclick="confirmScenes()" style="max-width:200px;margin-top:12px;">✓ Confirm Scenes</button>
        </div>
      </div>

      <!-- ══ STEP 6: SCENE IMAGES ══ -->
      <div class="auto-step-panel" id="auto-step-6">
        <div class="auto-step-header">
          <div class="auto-step-title">🎨 Step 6 — Generate Scene Images</div>
          <div class="auto-step-desc">Kie.ai generates a reference image for each scene using Nano Banana Pro, incorporating your skeleton reference.</div>
        </div>

        <div style="display:flex;gap:8px;margin-bottom:12px;">
          <button class="btn" id="sceneImgsBtn" onclick="generateSceneImages()" style="max-width:280px;">🎨 Generate All Scene Images</button>
        </div>

        <div class="auto-loading" id="sceneImgsLoading">
          <div class="auto-spinner"></div>
          <span id="sceneImgsLoadingTxt">Generating scene images…</span>
        </div>

        <div id="sceneImgsOutput" style="display:none;">
          <div id="sceneImgsGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;"></div>
          <button class="btn" onclick="confirmSceneImages()" style="max-width:200px;margin-top:12px;">✓ Confirm Images</button>
        </div>
      </div>

      <!-- ══ STEP 7: GENERATE CLIPS ══ -->
      <div class="auto-step-panel" id="auto-step-7">
        <div class="auto-step-header">
          <div class="auto-step-title">⚡ Step 7 — Generate Video Clips</div>
          <div class="auto-step-desc">Generate each scene as a video clip using your chosen AI model. Clips are generated one by one.</div>
        </div>

        <div class="card" style="margin-bottom:12px;">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Video Model</label>
              <select class="select" id="autoVideoModel">
                <option value="grok">Grok Imagine — 30cr (Best for character consistency)</option>
                <option value="veo3-lite">Veo 3.1 Lite — 20cr (Best quality)</option>
                <option value="sora2">Sora 2 — 20cr (Cinematic)</option>
              </select>
            </div>
            <div class="setting-row">
              <label class="setting-label">Aspect Ratio</label>
              <select class="select" id="autoAspect">
                <option value="9:16" selected>9:16 (Portrait — TikTok)</option>
                <option value="16:9">16:9 (Landscape)</option>
              </select>
            </div>
          </div>
        </div>

        <button class="btn" id="clipsBtn" onclick="generateAllClips()" style="max-width:280px;">⚡ Generate All Clips</button>

        <div id="clipsOutput" style="display:none;margin-top:16px;">
          <div class="sec-lbl" style="margin-bottom:8px;">Generated Clips</div>
          <div id="clipsList" style="display:flex;flex-direction:column;gap:10px;"></div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
/* ══ AUTOMATION STYLES ══ */
.auto-step-btn {
  display:flex;align-items:center;gap:8px;padding:8px 9px;border-radius:7px;
  font-size:11px;font-weight:600;color:var(--tdim);border:1px solid transparent;
  cursor:pointer;background:none;width:100%;text-align:left;transition:all .15s;
}
.auto-step-btn:hover { background:var(--s2);color:var(--tx); }
.auto-step-btn.active { background:var(--yg);border-color:rgba(245,225,50,.18);color:var(--y); }
.auto-step-btn.done { color:var(--grn); }
.auto-step-btn.done .step-num { background:var(--grn);color:#000; }
.step-num {
  width:18px;height:18px;border-radius:50%;background:var(--s4);
  font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;font-family:'Space Mono',monospace;
}
.step-label { flex:1; }
.step-check { font-size:10px; }

.auto-step-panel { display:none;flex-direction:column;gap:14px; }
.auto-step-panel.active { display:flex; }

.auto-step-header { border-bottom:1px solid var(--bd);padding-bottom:12px; }
.auto-step-title { font-family:'Space Mono',monospace;font-size:13px;font-weight:700;color:var(--y);margin-bottom:4px; }
.auto-step-desc { font-size:11px;color:var(--tdim);line-height:1.6; }

.auto-loading {
  display:none;align-items:center;gap:10px;padding:12px;
  background:var(--s2);border:1px solid var(--bd);border-radius:9px;
  font-size:11px;color:var(--tdim);
}
.auto-loading.vis { display:flex; }
.auto-spinner {
  width:16px;height:16px;border:2px solid var(--bd);border-top-color:var(--y);
  border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0;
}
@keyframes spin { to { transform:rotate(360deg); } }

.idea-card {
  padding:12px;background:var(--s2);border:1px solid var(--bd);border-radius:9px;
  cursor:pointer;transition:all .15s;
}
.idea-card:hover { border-color:rgba(245,225,50,.3); }
.idea-card.selected { border-color:rgba(245,225,50,.5);background:rgba(245,225,50,.04); }
.idea-title { font-size:12px;font-weight:700;color:var(--tx);margin-bottom:4px; }
.idea-why { font-size:10px;color:var(--tdim);line-height:1.5; }

.scene-card {
  background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:12px;
  display:flex;flex-direction:column;gap:8px;
}
.scene-card-header { display:flex;justify-content:space-between;align-items:center; }
.scene-num { font-size:9px;font-weight:700;color:var(--y);font-family:'Space Mono',monospace; }
.scene-del-btn {
  background:none;border:none;color:var(--tmut);cursor:pointer;font-size:12px;
  padding:2px 6px;border-radius:4px;
}
.scene-del-btn:hover { color:var(--red);background:rgba(255,65,54,.08); }
</style>

<script>
// ══════════════════════════════════════════════════════════════════
// AUTOMATION PIPELINE STATE
// ══════════════════════════════════════════════════════════════════
const autoState = {
  currentStep: 1,
  completedSteps: new Set(),
  selectedIdea: null,
  script: null,
  refVideoStructure: null,
  refImageFile: null,
  refImageB64: null,
  scenes: [],
  sceneImages: [],
  clips: [],
};

function gotoStep(n) {
  document.querySelectorAll('.auto-step-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.auto-step-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('auto-step-' + n).classList.add('active');
  document.getElementById('step-btn-' + n).classList.add('active');
  autoState.currentStep = n;
}

function markStepDone(n) {
  autoState.completedSteps.add(n);
  const btn = document.getElementById('step-btn-' + n);
  btn.classList.add('done');
  document.getElementById('step-check-' + n).textContent = '✓';
  updateProgress();
}

function updateProgress() {
  const done = autoState.completedSteps.size;
  const pct = (done / 7) * 100;
  document.getElementById('pipelineProgress').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = done + ' / 7 steps';
}

function skipStep(n) {
  markStepDone(n);
  gotoStep(n + 1);
}

// ══ STEP 1: IDEATION ══
async function runIdeation() {
  const competitorData = document.getElementById('autoCompetitorData').value.trim();
  const niche = document.getElementById('autoNiche').value.trim();
  const ownIdea = document.getElementById('autoOwnIdea').value.trim();

  if (ownIdea) {
    autoState.selectedIdea = ownIdea;
    document.getElementById('selectedIdeaDisplay').textContent = ownIdea;
    markStepDone(1);
    gotoStep(2);
    return;
  }

  if (!competitorData && !niche) {
    alert('Please paste competitor data or enter your niche/topic.');
    return;
  }

  document.getElementById('ideationBtn').disabled = true;
  document.getElementById('ideationLoading').classList.add('vis');
  document.getElementById('ideasOutput').style.display = 'none';

  try {
    let prompt = `You are a viral short-form video content strategist.\n\n`;
    if (competitorData) {
      let parsed;
      try { parsed = JSON.parse(competitorData); } catch(e) { parsed = null; }
      if (parsed && Array.isArray(parsed)) {
        const top = parsed.slice(0, 10).map(v => `- "${v.title}" (${(v.view_count/1000).toFixed(0)}K views)${v.transcript ? '\n  Transcript: ' + v.transcript.slice(0, 200) : ''}`).join('\n');
        prompt += `Here are the top performing videos from a competitor channel:\n${top}\n\n`;
      } else {
        prompt += `Competitor data: ${competitorData.slice(0, 1000)}\n\n`;
      }
    }
    if (niche) prompt += `Niche/Topic: ${niche}\n\n`;
    prompt += `Based on this data, suggest exactly 5 viral short-form video ideas (under 90 seconds each). For each idea provide:
1. A punchy title/hook (max 10 words)
2. Why it will go viral (1-2 sentences)
3. The emotional trigger it uses

Respond in JSON only, no markdown, like this:
[{"title":"...","why":"...","emotion":"..."},...]`;

    const response = await fetch('/api/claude', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt })
    });
    const data = await response.json();
    let ideas;
    try {
      const text = data.content?.[0]?.text || '';
      const clean = text.replace(/```json|```/g, '').trim();
      ideas = JSON.parse(clean);
    } catch(e) {
      throw new Error('Could not parse ideas from Claude');
    }

    renderIdeas(ideas);
  } catch(err) {
    alert('Error: ' + err.message);
  }

  document.getElementById('ideationBtn').disabled = false;
  document.getElementById('ideationLoading').classList.remove('vis');
}

function renderIdeas(ideas) {
  const list = document.getElementById('ideasList');
  list.innerHTML = '';
  ideas.forEach((idea, i) => {
    const card = document.createElement('div');
    card.className = 'idea-card';
    card.innerHTML = `
      <div class="idea-title">${i+1}. ${idea.title}</div>
      <div class="idea-why">${idea.why}</div>
      <div style="font-size:9px;color:var(--pur);margin-top:4px;">💫 ${idea.emotion}</div>
    `;
    card.onclick = () => {
      document.querySelectorAll('.idea-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      autoState.selectedIdea = idea.title;
    };
    list.appendChild(card);
  });
  document.getElementById('ideasOutput').style.display = 'block';
}

function confirmIdea() {
  if (!autoState.selectedIdea) { alert('Please select an idea first.'); return; }
  document.getElementById('selectedIdeaDisplay').textContent = autoState.selectedIdea;
  markStepDone(1);
  gotoStep(2);
}

// ══ STEP 2: SCRIPT ══
async function generateScript() {
  if (!autoState.selectedIdea) { alert('Please complete Step 1 first.'); return; }

  document.getElementById('scriptBtn').disabled = true;
  document.getElementById('scriptLoading').classList.add('vis');
  document.getElementById('scriptOutput').style.display = 'none';

  try {
    const direction = document.getElementById('scriptPrompt').value.trim();
    const competitorData = document.getElementById('autoCompetitorData').value.trim();

    let avgDuration = 60;
    try {
      const parsed = JSON.parse(competitorData);
      if (Array.isArray(parsed) && parsed.length > 0) {
        avgDuration = Math.round(parsed.slice(0, 5).reduce((a, v) => a + (v.duration_seconds || 60), 0) / Math.min(5, parsed.length));
      }
    } catch(e) {}

    const prompt = `You are a viral short-form video scriptwriter.

Video concept: "${autoState.selectedIdea}"
Target duration: ${avgDuration} seconds
${direction ? 'Additional direction: ' + direction : ''}

Write a complete, punchy viral script for this video. Include:
- A hook in the first 3 seconds that stops the scroll
- Natural spoken dialogue (no stage directions, just the words to say)
- A strong ending/call to action

The script should be exactly right for ${avgDuration} seconds of speech. Write ONLY the script text, nothing else.`;

    const response = await fetch('/api/claude', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt, max_tokens: 1000 })
    });
    const data = await response.json();
    const script = data.content?.[0]?.text || '';

    document.getElementById('finalScript').value = script;
    const words = script.split(/\s+/).length;
    document.getElementById('scriptWordCount').textContent = `~${words} words · ~${Math.round(words/2.5)} seconds`;
    document.getElementById('scriptOutput').style.display = 'block';
    autoState.script = script;

  } catch(err) {
    alert('Error: ' + err.message);
  }

  document.getElementById('scriptBtn').disabled = false;
  document.getElementById('scriptLoading').classList.remove('vis');
}

function confirmScript() {
  autoState.script = document.getElementById('finalScript').value.trim();
  if (!autoState.script) { alert('Script is empty.'); return; }
  markStepDone(2);
  gotoStep(3);
}

// ══ STEP 3: REFERENCE VIDEO ══
async function analyseRefVideo() {
  const url = document.getElementById('refVideoUrl').value.trim();
  if (!url) { alert('Please enter a video URL.'); return; }

  document.getElementById('refVideoLoading').classList.add('vis');
  document.getElementById('refVideoOutput').style.display = 'none';

  try {
    const prompt = `You are a video editor analysing a video's structure.

Video URL: ${url}

Based on typical viral short-form videos of this type, describe how this video would likely be structured into scenes. Assume it's a ${autoState.selectedIdea || 'viral short'} style video.

Return JSON only:
[{"scene":1,"duration":"0-5s","description":"...","type":"hook|main|cta"},...]

Give 4-8 scenes.`;

    const response = await fetch('/api/claude', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt })
    });
    const data = await response.json();
    let scenes;
    try {
      const text = data.content?.[0]?.text || '';
      scenes = JSON.parse(text.replace(/```json|```/g, '').trim());
    } catch(e) {
      throw new Error('Could not parse scene structure');
    }

    autoState.refVideoStructure = scenes;
    const container = document.getElementById('refVideoScenes');
    container.innerHTML = scenes.map(s => `
      <div style="display:flex;gap:10px;align-items:flex-start;padding:8px;background:var(--s2);border:1px solid var(--bd);border-radius:7px;">
        <div style="font-size:9px;color:var(--y);font-family:'Space Mono',monospace;white-space:nowrap;padding-top:2px;">Scene ${s.scene}<br>${s.duration}</div>
        <div style="font-size:11px;color:var(--tx);">${s.description}</div>
        <div style="font-size:8px;padding:2px 5px;border-radius:3px;background:var(--s4);color:var(--tdim);white-space:nowrap;">${s.type}</div>
      </div>
    `).join('');
    document.getElementById('refVideoOutput').style.display = 'block';

  } catch(err) {
    alert('Error: ' + err.message);
  }

  document.getElementById('refVideoLoading').classList.remove('vis');
}

function confirmRefVideo() {
  markStepDone(3);
  gotoStep(4);
}

// ══ STEP 4: REFERENCE IMAGE ══
const refImgDropAuto = document.getElementById('refImgDropAuto');
const refImgInputAuto = document.getElementById('refImgInputAuto');
refImgDropAuto.addEventListener('dragover', e => { e.preventDefault(); refImgDropAuto.classList.add('drag'); });
refImgDropAuto.addEventListener('dragleave', () => refImgDropAuto.classList.remove('drag'));
refImgDropAuto.addEventListener('drop', e => {
  e.preventDefault(); refImgDropAuto.classList.remove('drag');
  if (e.dataTransfer.files[0]) loadRefImgAuto(e.dataTransfer.files[0]);
});
refImgInputAuto.addEventListener('change', () => {
  if (refImgInputAuto.files[0]) loadRefImgAuto(refImgInputAuto.files[0]);
});

function loadRefImgAuto(f) {
  autoState.refImageFile = f;
  document.getElementById('refImgAutoFnm').textContent = '📎 ' + f.name;
  refImgDropAuto.classList.add('has-file');
  const reader = new FileReader();
  reader.onload = () => {
    autoState.refImageB64 = reader.result.split(',')[1];
    document.getElementById('refImgAutoImg').src = reader.result;
    document.getElementById('refImgAutoPreview').style.display = 'block';
    document.getElementById('confirmRefImgBtn').disabled = false;
  };
  reader.readAsDataURL(f);
}

function confirmRefImg() {
  markStepDone(4);
  gotoStep(5);
}

// ══ STEP 5: SCENES ══
async function generateScenes() {
  if (!autoState.script) { alert('Please complete Step 2 first.'); return; }

  document.getElementById('scenesBtn').disabled = true;
  document.getElementById('scenesLoading').classList.add('vis');
  document.getElementById('scenesOutput').style.display = 'none';

  try {
    const prompt = `You are a video director and AI image prompt expert.

Script:
"${autoState.script}"

Split this script into 4-8 scenes for a short-form vertical video (9:16). For each scene:
1. Extract the exact script lines for that scene
2. Write an optimised Kie.ai/Nano Banana Pro image generation prompt that will create the perfect reference image for that scene

The image prompts should be cinematic, detailed, and specify: subject, action, environment, lighting, style, camera angle.

Return JSON only:
[{"scene":1,"script_lines":"...","image_prompt":"...","duration_seconds":5},...]`;

    const response = await fetch('/api/claude', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt, max_tokens: 2000 })
    });
    const data = await response.json();
    let scenes;
    try {
      const text = data.content?.[0]?.text || '';
      scenes = JSON.parse(text.replace(/```json|```/g, '').trim());
    } catch(e) {
      throw new Error('Could not parse scenes from Claude');
    }

    autoState.scenes = scenes;
    renderScenes();
    document.getElementById('scenesOutput').style.display = 'block';

  } catch(err) {
    alert('Error: ' + err.message);
  }

  document.getElementById('scenesBtn').disabled = false;
  document.getElementById('scenesLoading').classList.remove('vis');
}

function renderScenes() {
  const list = document.getElementById('scenesList');
  list.innerHTML = '';
  document.getElementById('sceneCount').textContent = `(${autoState.scenes.length})`;
  autoState.scenes.forEach((scene, i) => {
    const card = document.createElement('div');
    card.className = 'scene-card';
    card.id = 'scene-card-' + i;
    card.innerHTML = `
      <div class="scene-card-header">
        <div class="scene-num">SCENE ${scene.scene} · ~${scene.duration_seconds}s</div>
        <button class="scene-del-btn" onclick="deleteScene(${i})">✕</button>
      </div>
      <div>
        <div class="sec-lbl" style="margin-bottom:4px;">Script Lines</div>
        <textarea class="textarea" rows="2" style="font-size:11px;" onchange="autoState.scenes[${i}].script_lines=this.value">${scene.script_lines}</textarea>
      </div>
      <div>
        <div class="sec-lbl" style="margin-bottom:4px;">Image Prompt</div>
        <textarea class="textarea" rows="3" style="font-size:11px;" onchange="autoState.scenes[${i}].image_prompt=this.value">${scene.image_prompt}</textarea>
      </div>
    `;
    list.appendChild(card);
  });
}

function deleteScene(i) {
  autoState.scenes.splice(i, 1);
  autoState.scenes.forEach((s, idx) => s.scene = idx + 1);
  renderScenes();
}

function addScene() {
  autoState.scenes.push({
    scene: autoState.scenes.length + 1,
    script_lines: '',
    image_prompt: '',
    duration_seconds: 5
  });
  renderScenes();
}

function confirmScenes() {
  if (autoState.scenes.length === 0) { alert('Add at least one scene.'); return; }
  markStepDone(5);
  gotoStep(6);
}

// ══ STEP 6: SCENE IMAGES ══
async function generateSceneImages() {
  if (autoState.scenes.length === 0) { alert('Please complete Step 5 first.'); return; }

  document.getElementById('sceneImgsBtn').disabled = true;
  document.getElementById('sceneImgsLoading').classList.add('vis');
  document.getElementById('sceneImgsOutput').style.display = 'none';
  autoState.sceneImages = [];

  const grid = document.getElementById('sceneImgsGrid');
  grid.innerHTML = '';

  for (let i = 0; i < autoState.scenes.length; i++) {
    const scene = autoState.scenes[i];
    document.getElementById('sceneImgsLoadingTxt').textContent = `Generating scene ${i+1} of ${autoState.scenes.length}…`;

    // Placeholder card
    const card = document.createElement('div');
    card.style.cssText = 'background:var(--s2);border:1px solid var(--bd);border-radius:8px;overflow:hidden;aspect-ratio:9/16;display:flex;flex-direction:column;';
    card.innerHTML = `
      <div style="flex:1;display:flex;align-items:center;justify-content:center;color:var(--tdim);font-size:10px;" id="scene-img-placeholder-${i}">
        <div class="auto-spinner" style="width:20px;height:20px;border-width:2px;"></div>
      </div>
      <div style="padding:6px;font-size:9px;color:var(--tdim);font-family:'Space Mono',monospace;">Scene ${scene.scene}</div>
    `;
    grid.appendChild(card);

    try {
      let prompt = scene.image_prompt;
      if (autoState.refImageB64) {
        prompt += ', consistent character design, reference character style';
      }

      const fd = new FormData();
      fd.append('model', 'nano-banana-pro');
      fd.append('prompt', prompt);
      fd.append('aspectRatio', '9:16');
      fd.append('resolution', '1K');
      fd.append('format', 'PNG');

      if (autoState.refImageFile) {
        fd.append('refImage', autoState.refImageFile);
      }

      const res = await fetch('/generate-image', { method: 'POST', body: fd });
      const data = await res.json();

      if (data.success) {
        autoState.sceneImages[i] = data.imageUrl;
        const placeholder = document.getElementById('scene-img-placeholder-' + i);
        if (placeholder) {
          placeholder.innerHTML = `<img src="${data.imageUrl}" style="width:100%;height:100%;object-fit:cover;">`;
        }
      } else {
        throw new Error(data.error);
      }
    } catch(err) {
      const placeholder = document.getElementById('scene-img-placeholder-' + i);
      if (placeholder) placeholder.innerHTML = `<span style="font-size:9px;color:var(--red);padding:8px;text-align:center;">Error: ${err.message}</span>`;
    }
  }

  document.getElementById('sceneImgsBtn').disabled = false;
  document.getElementById('sceneImgsLoading').classList.remove('vis');
  document.getElementById('sceneImgsOutput').style.display = 'block';
}

function confirmSceneImages() {
  markStepDone(6);
  gotoStep(7);
}

// ══ STEP 7: GENERATE CLIPS ══
async function generateAllClips() {
  if (autoState.scenes.length === 0) { alert('Please complete the previous steps first.'); return; }

  document.getElementById('clipsBtn').disabled = true;
  document.getElementById('clipsOutput').style.display = 'block';
  const clipsList = document.getElementById('clipsList');
  clipsList.innerHTML = '';

  const model = document.getElementById('autoVideoModel').value;
  const aspectRatio = document.getElementById('autoAspect').value;

  for (let i = 0; i < autoState.scenes.length; i++) {
    const scene = autoState.scenes[i];
    const sceneImg = autoState.sceneImages[i];

    // Add clip card
    const card = document.createElement('div');
    card.style.cssText = 'background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:12px;display:flex;gap:12px;align-items:flex-start;';
    card.innerHTML = `
      <div style="flex-shrink:0;width:60px;">
        ${sceneImg ? `<img src="${sceneImg}" style="width:60px;height:107px;object-fit:cover;border-radius:5px;border:1px solid var(--bd);">` : '<div style="width:60px;height:107px;background:var(--s3);border-radius:5px;border:1px solid var(--bd);"></div>'}
      </div>
      <div style="flex:1;min-width:0;">
        <div style="font-size:10px;font-weight:700;color:var(--y);font-family:\'Space Mono\',monospace;margin-bottom:4px;">Scene ${scene.scene}</div>
        <div style="font-size:10px;color:var(--tdim);margin-bottom:8px;line-height:1.4;">${scene.script_lines}</div>
        <div id="clip-status-${i}" style="font-size:10px;color:var(--tdim);font-family:\'Space Mono\',monospace;">⏳ Generating…</div>
        <div id="clip-video-${i}"></div>
      </div>
    `;
    clipsList.appendChild(card);

    try {
      const fd = new FormData();
      fd.append('model', model);
      fd.append('prompt', scene.image_prompt + ', cinematic motion, smooth camera movement');
      fd.append('duration', String(Math.max(5, scene.duration_seconds || 5)));
      fd.append('aspectRatio', aspectRatio);
      fd.append('quality', '720p');

      // Use scene image as reference if available
      if (sceneImg) {
        try {
          const imgRes = await fetch(sceneImg);
          const blob = await imgRes.blob();
          fd.append('image', blob, 'scene.jpg');
        } catch(e) {}
      }

      const res = await fetch('/generate-video', { method: 'POST', body: fd });
      const data = await res.json();

      if (data.success) {
        autoState.clips[i] = data.videoUrl;
        document.getElementById('clip-status-' + i).innerHTML = `<span style="color:var(--grn);">✓ Done</span>`;
        document.getElementById('clip-video-' + i).innerHTML = `
          <video controls src="${data.videoUrl}" style="width:100%;max-width:200px;border-radius:6px;margin-top:6px;"></video>
          <a href="${data.videoUrl}" download="scene_${scene.scene}.mp4" style="display:inline-block;margin-top:4px;font-size:9px;color:var(--yd);font-family:\'Space Mono\',monospace;">⬇ Download</a>
        `;
      } else {
        throw new Error(data.error);
      }
    } catch(err) {
      document.getElementById('clip-status-' + i).innerHTML = `<span style="color:var(--red);">✗ ${err.message}</span>`;
    }
  }

  document.getElementById('clipsBtn').disabled = false;
  markStepDone(7);
}
</script>

</div>

<!-- ══ ADD VOICE MODAL ══ -->
<div class="modal-overlay" id="addVoiceModal" style="display:none;">
  <div class="modal">
    <div class="modal-title">🎤 Add Custom Voice</div>
    <div class="upload-zone" id="modalAudioDrop" onclick="document.getElementById('modalAudioInput').click()">
      <input type="file" id="modalAudioInput" accept="audio/*" style="display:none">
      <span class="up-icon">🎙</span>
      <div class="up-title">Upload Voice Sample</div>
      <div class="up-hint">WAV · MP3 · M4A · 10–30 seconds</div>
      <div class="up-name" id="modalAudioFnm"></div>
    </div>
    <div>
      <div class="sec-lbl" style="margin-bottom:6px;">Voice Name</div>
      <input type="text" class="text-input" id="modalVoiceName" placeholder="e.g. My Voice, Devon, etc.">
    </div>
    <div class="modal-btns">
      <button class="modal-btn-cancel" onclick="closeAddVoiceModal()">Cancel</button>
      <button class="modal-btn-save" onclick="saveCustomVoice()">Save Voice</button>
    </div>
  </div>
</div>

<script>
// ══════════════════════════════════════════════════════════════════
// MODEL CONFIG
// ══════════════════════════════════════════════════════════════════
const MODEL_CONFIG = {
  'veo3-lite': {
    label:'Veo 3.1 Lite', credits:20, durations:[8], defaultDuration:8,
    aspectRatios:[{value:'9:16',label:'9:16 (Portrait)'},{value:'16:9',label:'16:9 (Landscape)'}],
    defaultAspect:'9:16', requiresImage:false,
  },
  'sora2': {
    label:'Sora 2', credits:20, durations:[12], defaultDuration:12,
    aspectRatios:[{value:'9:16',label:'9:16 (Portrait)'},{value:'16:9',label:'16:9 (Landscape)'}],
    defaultAspect:'9:16', requiresImage:false,
  },
  'grok': {
    label:'Grok Imagine', credits:30, durations:[6,10], defaultDuration:6,
    aspectRatios:[{value:'9:16',label:'9:16 (Portrait)'},{value:'2:3',label:'2:3 (Portrait)'},{value:'16:9',label:'16:9 (Landscape)'},{value:'3:2',label:'3:2 (Landscape)'},{value:'1:1',label:'1:1 (Square)'}],
    defaultAspect:'9:16', requiresImage:false,
    qualities:[{value:'720p',label:'720p — 30 credits'},{value:'480p',label:'480p — 15 credits'}],
    defaultQuality:'720p', creditsByQuality:{'720p':30,'480p':15},
  },
};

// ══ STATE ══
let credentials = { credits: 500 };
let selectedImg = null;
let selectedRefImg = null;

// ── Voice state ──
let selectedVoiceId = null;
let selectedVoiceName = null;
let modalAudioFile = null;

// Load custom voices from localStorage
function loadCustomVoices() {
  try { return JSON.parse(localStorage.getItem('dubshorts_custom_voices') || '[]'); } catch(e) { return []; }
}
function saveCustomVoices(voices) {
  localStorage.setItem('dubshorts_custom_voices', JSON.stringify(voices));
}

// ══ TAB SWITCHING ══
function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.ni').forEach(n => n.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  document.getElementById('nav-' + tab).classList.add('active');
  const titles = { vidgen:'AI Video Gen', imggen:'AI Image Gen', voicegen:'Voice Gen', deadspace:'Dead Space Remover', scraper:'YT Scraper', repurpose:'Repurpose & Distribute', automation:'Automation Pipeline' };
  document.getElementById('topTitle').textContent = titles[tab] || 'DubShorts';
}

function updateCreditsDisplay() {
  document.getElementById('creditsDisplay').textContent = credentials.credits + ' Credits';
}

// ══════════════════════════════════════════════════════════════════
// VIDEO GEN
// ══════════════════════════════════════════════════════════════════
function onModelChange() {
  const model = document.getElementById('vidModel').value;
  const cfg = MODEL_CONFIG[model];
  if (!cfg) return;
  const durSel = document.getElementById('vidDuration');
  durSel.innerHTML = '';
  cfg.durations.forEach(d => { const o = document.createElement('option'); o.value = d; o.textContent = d + ' seconds'; if (d === cfg.defaultDuration) o.selected = true; durSel.appendChild(o); });
  const aspSel = document.getElementById('vidAspect');
  aspSel.innerHTML = '';
  cfg.aspectRatios.forEach(ar => { const o = document.createElement('option'); o.value = ar.value; o.textContent = ar.label; if (ar.value === cfg.defaultAspect) o.selected = true; aspSel.appendChild(o); });
  const qualityRow = document.getElementById('qualityRow');
  const qualitySel = document.getElementById('vidQuality');
  if (cfg.qualities) {
    qualityRow.style.display = '';
    qualitySel.innerHTML = '';
    cfg.qualities.forEach(q => { const o = document.createElement('option'); o.value = q.value; o.textContent = q.label; if (q.value === cfg.defaultQuality) o.selected = true; qualitySel.appendChild(o); });
    document.getElementById('vidCost').textContent = cfg.creditsByQuality[cfg.defaultQuality] + ' credits';
  } else {
    qualityRow.style.display = 'none';
    document.getElementById('vidCost').textContent = cfg.credits + ' credits';
  }
}

function onQualityChange() {
  const cfg = MODEL_CONFIG[document.getElementById('vidModel').value];
  if (cfg && cfg.creditsByQuality) document.getElementById('vidCost').textContent = cfg.creditsByQuality[document.getElementById('vidQuality').value] + ' credits';
}

const imgDrop = document.getElementById('imgDrop');
const imgInput = document.getElementById('imgInput');
imgDrop.addEventListener('dragover', e => { e.preventDefault(); imgDrop.classList.add('drag'); });
imgDrop.addEventListener('dragleave', () => imgDrop.classList.remove('drag'));
imgDrop.addEventListener('drop', e => { e.preventDefault(); imgDrop.classList.remove('drag'); const f = e.dataTransfer.files[0]; if (f && f.type.startsWith('image/')) loadImg(f); });
imgInput.addEventListener('change', () => { if (imgInput.files[0]) loadImg(imgInput.files[0]); });
function loadImg(f) { selectedImg = f; document.getElementById('imgFnm').textContent = '📎 ' + f.name; imgDrop.classList.add('has-file'); }

async function startVidGen() {
  const prompt = document.getElementById('aivgPrompt').value.trim();
  if (!prompt) { alert('Please enter a prompt.'); return; }
  const model = document.getElementById('vidModel').value;
  const cfg = MODEL_CONFIG[model];
  const duration = document.getElementById('vidDuration').value;
  const aspectRatio = document.getElementById('vidAspect').value;
  const quality = cfg.qualities ? document.getElementById('vidQuality').value : '720p';
  const btn = document.getElementById('vidBtn');
  btn.disabled = true; btn.textContent = '⏳ Generating…';
  document.getElementById('vidProg').classList.add('vis');
  document.getElementById('vidErr').classList.remove('vis');
  document.getElementById('vidResultBtns').classList.remove('vis');
  let pct = 0;
  const fill = document.getElementById('vpFill'), lbl = document.getElementById('vpLbl'), pctLbl = document.getElementById('vpPct');
  const stages = ['Submitting job…','Queued…','Generating frames…','Finalizing…']; let si = 0; lbl.textContent = stages[0];
  const tick = setInterval(() => {
    if (pct < 85) { pct += Math.random() * 1.2; if (pct > 85) pct = 85; fill.style.width = pct + '%'; pctLbl.textContent = Math.round(pct) + '%';
      if (pct > 20 && si < 1) { si=1; lbl.textContent = stages[1]; }
      if (pct > 45 && si < 2) { si=2; lbl.textContent = stages[2]; }
      if (pct > 75 && si < 3) { si=3; lbl.textContent = stages[3]; }
    }
  }, 1000);
  try {
    const fd = new FormData();
    if (selectedImg) fd.append('image', selectedImg);
    fd.append('model', model); fd.append('prompt', prompt); fd.append('duration', duration); fd.append('aspectRatio', aspectRatio); fd.append('audio', '1'); fd.append('quality', quality);
    const res = await fetch('/generate-video', { method: 'POST', body: fd });
    const data = await res.json();
    clearInterval(tick); fill.style.width = '100%'; pctLbl.textContent = '100%'; lbl.textContent = 'Done!';
    if (!data.success) throw new Error(data.error || 'Unknown error');
    const vid = document.getElementById('vidVideo');
    vid.src = data.videoUrl; vid.style.display = 'block';
    document.getElementById('vidEmpty').style.display = 'none';
    document.getElementById('vidDlBtn').href = data.videoUrl;
    document.getElementById('vidResultBtns').classList.add('vis');
    credentials.credits -= cfg.qualities ? cfg.creditsByQuality[quality] : cfg.credits;
    updateCreditsDisplay();
  } catch(err) {
    clearInterval(tick);
    document.getElementById('vidErr').classList.add('vis');
    document.getElementById('vidErrMsg').textContent = err.message;
  }
  btn.disabled = false; btn.textContent = '⚡ Generate Video';
  setTimeout(() => document.getElementById('vidProg').classList.remove('vis'), 2000);
}

// ══════════════════════════════════════════════════════════════════
// IMAGE GEN
// ══════════════════════════════════════════════════════════════════
const IMG_MODEL_CONFIG = {
  'nano-banana-pro': { resolutions:['1K','2K','4K'], defaultRes:'1K', credits:{'1K':18,'2K':18,'4K':24} },
  'nano-banana-2':   { resolutions:['1K','2K','4K'], defaultRes:'1K', credits:{'1K':8,'2K':12,'4K':18} },
};
const refImgDrop = document.getElementById('refImgDrop');
const refImgInput = document.getElementById('refImgInput');
refImgDrop.addEventListener('dragover', e => { e.preventDefault(); refImgDrop.classList.add('drag'); });
refImgDrop.addEventListener('dragleave', () => refImgDrop.classList.remove('drag'));
refImgDrop.addEventListener('drop', e => { e.preventDefault(); refImgDrop.classList.remove('drag'); const f = e.dataTransfer.files[0]; if (f) { selectedRefImg = f; document.getElementById('refImgFnm').textContent = '📎 ' + f.name; refImgDrop.classList.add('has-file'); } });
refImgInput.addEventListener('change', () => { if (refImgInput.files[0]) { selectedRefImg = refImgInput.files[0]; document.getElementById('refImgFnm').textContent = '📎 ' + selectedRefImg.name; refImgDrop.classList.add('has-file'); } });

function onImgModelChange() {
  document.getElementById('imgCost').textContent = '18 credits';
}
function onImgResChange() {}
function onImgAspectChange() {
  const map = {'9:16':'9/16','16:9':'16/9','1:1':'1/1'};
  document.getElementById('imgPreviewWrap').style.aspectRatio = map[document.getElementById('imgAspect').value] || '1/1';
}

async function startImgGen() {
  const prompt = document.getElementById('imgPrompt').value.trim();
  if (!prompt) { alert('Please enter a prompt.'); return; }
  const model = document.getElementById('imgModel').value;
  const aspect = document.getElementById('imgAspect').value;
  const resolution = '1K';
  const format = 'PNG';
  const cfg = IMG_MODEL_CONFIG[model];
  const btn = document.getElementById('imgBtn');
  btn.disabled = true; btn.textContent = '⏳ Generating…';
  document.getElementById('imgProg').classList.add('vis');
  document.getElementById('imgErr').classList.remove('vis');
  document.getElementById('dlImgBtn').style.display = 'none';
  let pct = 0;
  const fill = document.getElementById('ipFill'), pctLbl = document.getElementById('ipPct');
  const tick = setInterval(() => { if (pct < 90) { pct += Math.random() * 3; if (pct > 90) pct = 90; fill.style.width = pct + '%'; pctLbl.textContent = Math.round(pct) + '%'; } }, 600);
  try {
    const fd = new FormData();
    fd.append('model', model); fd.append('prompt', prompt); fd.append('aspectRatio', aspect); fd.append('resolution', resolution); fd.append('format', format);
    if (selectedRefImg) fd.append('refImage', selectedRefImg);
    const res = await fetch('/generate-image', { method: 'POST', body: fd });
    const data = await res.json();
    clearInterval(tick); fill.style.width = '100%'; pctLbl.textContent = '100%';
    if (!data.success) throw new Error(data.error || 'Unknown error');
    const prev = document.getElementById('genImgPrev');
    prev.src = data.imageUrl; prev.style.display = 'block';
    document.getElementById('imgEmpty').style.display = 'none';
    const dl = document.getElementById('dlImgBtn');
    dl.href = data.imageUrl; dl.style.display = 'block';
    credentials.credits -= cfg.credits[resolution] || 0;
    updateCreditsDisplay();
  } catch(err) {
    clearInterval(tick);
    document.getElementById('imgErr').classList.add('vis');
    document.getElementById('imgErrMsg').textContent = err.message || String(err);
  }
  btn.disabled = false; btn.textContent = '🎨 Generate Image';
  setTimeout(() => document.getElementById('imgProg').classList.remove('vis'), 2000);
}

// ══════════════════════════════════════════════════════════════════
// VOICE GEN — all Chatterbox, no Kie.ai
// ══════════════════════════════════════════════════════════════════

function renderVoiceDropdown() {
  const sel = document.getElementById('voiceDropdown');
  const voices = loadCustomVoices();
  const currentId = selectedVoiceId;
  sel.innerHTML = '';
  // Mark always first
  // Custom voices
  voices.forEach(v => {
    const opt = document.createElement('option');
    opt.value = v.id;
    opt.textContent = v.name;
    sel.appendChild(opt);
  });
  // Restore selection
  sel.value = currentId || '';
  updateDeleteBtn();
}

function onVoiceDropdownChange() {
  const sel = document.getElementById('voiceDropdown');
  selectedVoiceId = sel.value;
  const voices = loadCustomVoices();
  if (selectedVoiceId === '__chatterbox_default__') {
    selectedVoiceName = null;
  } else {
    const v = voices.find(x => x.id === selectedVoiceId);
    selectedVoiceName = v ? v.name : 'Custom';
  }
  updateDeleteBtn();
}

function updateDeleteBtn() {
  const btn = document.getElementById('deleteVoiceBtn');
  btn.style.display = selectedVoiceId !== '__chatterbox_default__' ? 'block' : 'none';
}

function deleteSelectedVoice() {
  
  if (!confirm('Delete "' + selectedVoiceName + '"?')) return;
  const voices = loadCustomVoices().filter(v => v.id !== selectedVoiceId);
  saveCustomVoices(voices);
  selectedVoiceId = null;
  selectedVoiceName = null;
  renderVoiceDropdown();
}

function selectVoice(id, name) {
  selectedVoiceId = id;
  selectedVoiceName = name;
  renderVoiceDropdown();
}

function renderCustomVoices() {
  renderVoiceDropdown();
}

function deleteCustomVoice(id) {
  const voices = loadCustomVoices().filter(v => v.id !== id);
  saveCustomVoices(voices);
  if (selectedVoiceId === id) { selectedVoiceId = null; selectedVoiceName = null; }
  renderVoiceDropdown();
}

// Modal
function openAddVoiceModal() {
  modalAudioFile = null;
  document.getElementById('modalAudioFnm').textContent = '';
  document.getElementById('modalVoiceName').value = '';
  document.getElementById('modalAudioDrop').classList.remove('has-file');
  document.getElementById('addVoiceModal').style.display = 'flex';
}
function closeAddVoiceModal() {
  document.getElementById('addVoiceModal').style.display = 'none';
}

const modalAudioInput = document.getElementById('modalAudioInput');
const modalAudioDrop = document.getElementById('modalAudioDrop');
modalAudioDrop.addEventListener('dragover', e => { e.preventDefault(); modalAudioDrop.classList.add('drag'); });
modalAudioDrop.addEventListener('dragleave', () => modalAudioDrop.classList.remove('drag'));
modalAudioDrop.addEventListener('drop', e => { e.preventDefault(); modalAudioDrop.classList.remove('drag'); const f = e.dataTransfer.files[0]; if (f) loadModalAudio(f); });
modalAudioInput.addEventListener('change', () => { if (modalAudioInput.files[0]) loadModalAudio(modalAudioInput.files[0]); });
function loadModalAudio(f) {
  modalAudioFile = f;
  document.getElementById('modalAudioFnm').textContent = '📎 ' + f.name;
  modalAudioDrop.classList.add('has-file');
}

function saveCustomVoice() {
  const name = document.getElementById('modalVoiceName').value.trim();
  if (!name) { alert('Please enter a name for this voice.'); return; }
  if (!modalAudioFile) { alert('Please upload a voice sample first.'); return; }
  const reader = new FileReader();
  reader.onload = () => {
    const b64 = reader.result.split(',')[1];
    const voices = loadCustomVoices();
    const id = 'custom_' + Date.now();
    voices.push({ id, name, audioB64: b64, mimeType: modalAudioFile.type });
    saveCustomVoices(voices);
    closeAddVoiceModal();
    renderVoiceDropdown();
    selectedVoiceId = id;
    selectedVoiceName = name;
    document.getElementById('voiceDropdown').value = id;
    updateDeleteBtn();
  };
  reader.readAsDataURL(modalAudioFile);
}

async function startVoiceGen() {
  const script = document.getElementById('voiceScript').value.trim();
  if (!script) { alert('Please enter a script.'); return; }
  if (script.length > 10000) { alert('Script too long — Chatterbox max is ~500 characters. Please shorten it.'); return; }
  if (!selectedVoiceId) { alert('Please select a voice first.'); return; }

  const btn = document.getElementById('voiceBtn');
  btn.disabled = true; btn.textContent = '⏳ Generating…';
  document.getElementById('voiceProg').classList.add('vis');
  document.getElementById('voiceErr').classList.remove('vis');
  // dl handled by output list

  let pct = 0;
  const fill = document.getElementById('vrFill'), pctLbl = document.getElementById('voiceProgPct'), lbl = document.getElementById('voiceProgLbl');
  // Slow progress for Chatterbox cold starts (can take 2-3 min)
  const tick = setInterval(() => {
    if (pct < 95) {
      const increment = pct < 30 ? 2 : pct < 60 ? 0.8 : pct < 85 ? 0.3 : 0.05;
      pct += Math.random() * increment;
      if (pct > 95) pct = 95;
      fill.style.width = pct + '%';
      pctLbl.textContent = Math.round(pct) + '%';
      if (pct > 15) lbl.textContent = 'Waiting for GPU…';
      if (pct > 40) lbl.textContent = 'Generating audio…';
      if (pct > 75) lbl.textContent = 'Almost done…';
    }
  }, 800);

  try {
    const fd = new FormData();
    fd.append('text', script);
    fd.append('exaggeration', document.getElementById('exagSlider').value);
    fd.append('cfgWeight', '0.5');
    fd.append('temperature', '0.8');

    if (selectedVoiceId === '__chatterbox_default__') {
      // No voice sample — Chatterbox default voice
      lbl.textContent = 'Generating with Chatterbox…';
    } else {
      // Custom cloned voice
      const voices = loadCustomVoices();
      const v = voices.find(x => x.id === selectedVoiceId);
      if (!v) throw new Error('Voice not found — please re-add it.');
      const byteStr = atob(v.audioB64);
      const ab = new ArrayBuffer(byteStr.length);
      const ia = new Uint8Array(ab);
      for (let i = 0; i < byteStr.length; i++) ia[i] = byteStr.charCodeAt(i);
      const blob = new Blob([ab], { type: v.mimeType || 'audio/wav' });
      fd.append('voiceSample', blob, 'voice.wav');
      lbl.textContent = 'Cloning voice on GPU…';
    }

    const res = await fetch('/generate-voice', { method: 'POST', body: fd });
    const data = await res.json();
    clearInterval(tick); fill.style.width = '100%'; pctLbl.textContent = '100%';
    if (!data.success) throw new Error(data.error || 'Voice generation failed');

    addVoiceOutput(data.audioUrl, script.slice(0, 60) + (script.length > 60 ? '…' : ''), selectedVoiceName);

  } catch(err) {
    clearInterval(tick);
    document.getElementById('voiceErr').classList.add('vis');
    document.getElementById('voiceErrMsg').textContent = err.message;
  }

  btn.disabled = false; btn.textContent = '🔊 Generate Speech';
  setTimeout(() => document.getElementById('voiceProg').classList.remove('vis'), 2000);
}

// ══ VOICE OUTPUT LIST ══
function loadVoiceOutputs() {
  try { return JSON.parse(localStorage.getItem('dubshorts_voice_outputs') || '[]'); } catch(e) { return []; }
}
function saveVoiceOutputs(outputs) {
  localStorage.setItem('dubshorts_voice_outputs', JSON.stringify(outputs));
}

function addVoiceOutput(audioUrl, scriptPreview, voiceName) {
  const outputs = loadVoiceOutputs();
  const id = 'vo_' + Date.now();
  outputs.unshift({ id, audioUrl, scriptPreview, voiceName, ts: Date.now() });
  saveVoiceOutputs(outputs);
  renderVoiceOutputs();
}

function deleteVoiceOutput(id, e) {
  e.stopPropagation();
  const outputs = loadVoiceOutputs().filter(o => o.id !== id);
  saveVoiceOutputs(outputs);
  renderVoiceOutputs();
}

function renderVoiceOutputs() {
  const list = document.getElementById('voiceOutputList');
  const empty = document.getElementById('voiceOutputEmpty');
  const outputs = loadVoiceOutputs();
  // Remove all output cards but keep empty state
  list.querySelectorAll('.vo-card').forEach(el => el.remove());
  if (outputs.length === 0) {
    if (empty) empty.style.display = 'block';
    return;
  }
  if (empty) empty.style.display = 'none';
  outputs.forEach(o => {
    const card = document.createElement('div');
    card.className = 'vo-card';
    card.style.cssText = 'background:var(--s2);border:1px solid var(--bd);border-radius:10px;padding:12px;display:flex;flex-direction:column;gap:8px;';
    const ts = new Date(o.ts).toLocaleString([], {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
    card.innerHTML = `
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div style="flex:1;min-width:0;">
          <div style="font-size:12px;font-weight:600;color:var(--tx);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${o.scriptPreview}</div>
          <div style="font-size:10px;color:var(--tdim);">🔊 ${o.voiceName} · ${ts}</div>
        </div>
        <button onclick="deleteVoiceOutput('${o.id}',event)" style="background:none;border:none;color:var(--tmut);cursor:pointer;font-size:14px;padding:2px 6px;border-radius:4px;margin-left:8px;flex-shrink:0;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--tmut)'">✕</button>
      </div>
      <audio controls src="${o.audioUrl}" style="width:100%;height:32px;"></audio>
      <a href="${o.audioUrl}" download="voiceover.wav" style="display:block;width:100%;padding:7px;background:var(--s3);border:1px solid var(--bd);border-radius:7px;color:var(--tdim);font-size:11px;font-weight:700;font-family:'Space Mono',monospace;text-align:center;text-decoration:none;transition:all .15s;" onmouseover="this.style.background='var(--grn)';this.style.color='#000'" onmouseout="this.style.background='var(--s3)';this.style.color='var(--tdim)'">⬇ Download</a>
    `;
    list.appendChild(card);
  });
}

// ══ VIDEO UPSCALER ══
const upscaleZone = document.getElementById('upscaleZone');
upscaleZone.addEventListener('dragover', e => { e.preventDefault(); upscaleZone.classList.add('drag'); });
upscaleZone.addEventListener('dragleave', () => upscaleZone.classList.remove('drag'));
upscaleZone.addEventListener('drop', e => { e.preventDefault(); upscaleZone.classList.remove('drag'); if (e.dataTransfer.files[0]) loadUpscale(e.dataTransfer.files[0]); });
document.getElementById('upscaleInput').addEventListener('change', () => { if (document.getElementById('upscaleInput').files[0]) loadUpscale(document.getElementById('upscaleInput').files[0]); });
function loadUpscale(f) { document.getElementById('upscaleFnm').textContent = '📎 ' + f.name; upscaleZone.classList.add('has-file'); document.getElementById('upscaleBtn').disabled = false; const vid = document.getElementById('upVid'); vid.src = URL.createObjectURL(f); vid.style.display = 'block'; }
function updateUpscaleCost() { const sel = document.getElementById('upscaleQuality'); document.getElementById('upCost').textContent = sel.options[sel.selectedIndex].dataset.cr + ' credits'; }
async function startUpscale() {
  const fileInput = document.getElementById('upscaleInput');
  const quality = document.getElementById('upscaleQuality').value;
  const btn = document.getElementById('upscaleBtn');
  const vid = document.getElementById('upVid');

  if (!fileInput.files[0]) { alert('Please select a video file first.'); return; }

  btn.disabled = true;
  btn.textContent = '⏳ Upscaling…';

  try {
    const fd = new FormData();
    fd.append('video', fileInput.files[0]);
    fd.append('quality', quality);

    const res = await fetch('/upscale-video', { method: 'POST', body: fd });
    const data = await res.json();
    if (!data.success) throw new Error(data.error || 'Upscale failed');

    vid.src = data.videoUrl;
    vid.style.display = 'block';

    // Add download button if not already there
    let dlWrap = document.getElementById('upscaleDlWrap');
    if (!dlWrap) {
      dlWrap = document.createElement('div');
      dlWrap.id = 'upscaleDlWrap';
      dlWrap.style.cssText = 'width:100%;max-width:315px;margin-top:8px;';
      dlWrap.innerHTML = `<a id="upscaleDlBtn" class="dl-btn" download="upscaled.mp4">⬇ Download Upscaled Video</a>`;
      document.getElementById('upVid').closest('.right-panel').appendChild(dlWrap);
    }
    document.getElementById('upscaleDlBtn').href = data.videoUrl;

  } catch(err) {
    alert('Error: ' + err.message);
  }

  btn.disabled = false;
  btn.textContent = '📈 Upscale Video';
}

// ══ DEAD SPACE REMOVER ══
const deadspaceZone = document.getElementById('deadspaceZone');
deadspaceZone.addEventListener('dragover', e => { e.preventDefault(); deadspaceZone.classList.add('drag'); });
deadspaceZone.addEventListener('dragleave', () => deadspaceZone.classList.remove('drag'));
deadspaceZone.addEventListener('drop', e => { e.preventDefault(); deadspaceZone.classList.remove('drag'); if (e.dataTransfer.files[0]) loadDeadspace(e.dataTransfer.files[0]); });
document.getElementById('deadspaceInput').addEventListener('change', () => { if (document.getElementById('deadspaceInput').files[0]) loadDeadspace(document.getElementById('deadspaceInput').files[0]); });
function loadDeadspace(f) { document.getElementById('deadspaceFnm').textContent = '📎 ' + f.name; deadspaceZone.classList.add('has-file'); document.getElementById('dsBtn').disabled = false; const vid = document.getElementById('dsVid'); vid.src = URL.createObjectURL(f); vid.style.display = 'block'; }
function updateDbVal() {}
function setDsStrength(btn, val) {
  document.querySelectorAll('.ds-strength-btn').forEach(b => {
    b.style.background = 'var(--s3)';
    b.style.borderColor = 'var(--bd)';
    b.style.color = 'var(--tdim)';
  });
  btn.style.background = 'var(--yg)';
  btn.style.borderColor = 'rgba(245,225,50,.4)';
  btn.style.color = 'var(--y)';
  document.getElementById('dsStrength').value = val;
}
async function startDeadspace() {
  const fileInput = document.getElementById('deadspaceInput');
  if (!fileInput.files[0]) { alert('Please upload a video first.'); return; }
  const file = fileInput.files[0];
  const btn = document.getElementById('dsBtn');
  btn.disabled = true; btn.textContent = '⬆ Uploading…';
  try {
    const fd = new FormData();
    fd.append('video', file);
    fd.append('strength', document.getElementById('dsStrength').value);
    btn.textContent = '⏳ Processing…';
    const res = await fetch('/remove-deadspace', { method: 'POST', body: fd });
    const data = await res.json();
    if (!data.success) throw new Error(data.error || 'Processing failed');
    const vid = document.getElementById('dsVid');
    vid.src = data.videoUrl; vid.style.display = 'block';
    document.getElementById('dsEmpty').style.display = 'none';
    document.getElementById('dsDlBtn').href = data.videoUrl;
    document.getElementById('dsDlWrap').style.display = 'block';
  } catch(err) {
    alert('Error: ' + err.message);
  }
  btn.disabled = false; btn.textContent = '🎬 Remove Dead Space';
}
async function startScrape() {
  const url = document.getElementById('ytChannelUrl').value.trim();
  if (!url) { alert('Please enter a channel URL.'); return; }
  const btn = document.getElementById('scrapBtn');
  btn.disabled = true; btn.textContent = '⏳ Scraping…';
  document.getElementById('scrapErr').classList.remove('vis');
  document.getElementById('scrapList').innerHTML = '<div style="text-align:center;padding:30px;color:var(--tdim);font-size:11px;">⏳ Scraping channel… this may take a minute</div>';
  try {
    const res = await fetch('/scrape-channel', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        channelUrl: url,
        count: document.getElementById('ytCount').value,
        sort: document.getElementById('ytSort').value,
      })
    });
    const data = await res.json();
    if (!data.success) throw new Error(data.error || 'Scrape failed');
    renderScrapedVideos(data.videos);
  } catch(err) {
    document.getElementById('scrapErr').classList.add('vis');
    document.getElementById('scrapErrMsg').textContent = err.message;
    document.getElementById('scrapList').innerHTML = '<div style="text-align:center;padding:30px;color:var(--tdim);font-size:11px;">No data yet</div>';
  }
  btn.disabled = false; btn.textContent = '🎥 Scrape Channel';
}

// ══ REPURPOSE ══
function connectTiktok() { document.getElementById('tiktokStatus').textContent = 'Connected ✓'; }
function connectInstagram() { document.getElementById('instagramStatus').textContent = 'Connected ✓'; }
function startRepurpose() {
  if (!document.getElementById('repYtChannel').value.trim()) { alert('Please enter your YT channel link.'); return; }
  if (!document.getElementById('repTiktok').checked && !document.getElementById('repInstagram').checked) { alert('Select at least one platform.'); return; }
  if (document.getElementById('repTiktok').checked) connectTiktok();
  if (document.getElementById('repInstagram').checked) connectInstagram();
  document.getElementById('repStatus').textContent = 'Status: Active ✓';
}
document.getElementById('repTiktok').addEventListener('change', () => { document.getElementById('tiktokConnect').style.display = document.getElementById('repTiktok').checked ? 'block' : 'none'; });
document.getElementById('repInstagram').addEventListener('change', () => { document.getElementById('instagramConnect').style.display = document.getElementById('repInstagram').checked ? 'block' : 'none'; });

// Slider helpers
function updateSpeedVal()     { document.getElementById('speedVal').textContent      = document.getElementById('speedSlider').value; }
function updateStabilityVal() { document.getElementById('stabilityVal').textContent  = document.getElementById('stabilitySlider').value + '%'; }
function updateSimilarityVal(){ document.getElementById('similarityVal').textContent = document.getElementById('similaritySlider').value + '%'; }
function updateExagVal()      { document.getElementById('exagVal').textContent       = document.getElementById('exagSlider').value; }
function updateCharCount() { const n = document.getElementById('voiceScript').value.length; const el = document.getElementById('charCount'); el.textContent = n; el.style.color = n > 9000 ? 'var(--red)' : n > 7000 ? 'var(--yd)' : 'var(--tmut)'; }

// ══ INIT ══
onModelChange();
updateCreditsDisplay();
onImgModelChange();
// Init voice gen
selectedVoiceId = null;
selectedVoiceName = null;
renderVoiceDropdown();
renderVoiceOutputs();
document.getElementById('repTiktok').dispatchEvent(new Event('change'));
document.getElementById('repInstagram').dispatchEvent(new Event('change'));

function renderScrapedVideos(videos) {
  const list = document.getElementById('scrapList');
  if (!videos || videos.length === 0) {
    list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--tdim);font-size:11px;">No videos found</div>';
    return;
  }
  list.innerHTML = videos.map((v, i) => `
    <div style="padding:10px;border-bottom:1px solid var(--bd);display:flex;gap:10px;align-items:flex-start;">
      <div style="font-size:10px;color:var(--tmut);font-family:'Space Mono',monospace;width:16px;flex-shrink:0;padding-top:2px;">${i+1}</div>
      ${v.thumbnail ? `<img src="${v.thumbnail}" style="width:56px;height:100px;object-fit:cover;border-radius:5px;flex-shrink:0;">` : ''}
      <div style="flex:1;min-width:0;">
        <div style="font-size:11px;font-weight:600;color:var(--tx);margin-bottom:4px;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${v.title}</div>
        <div style="font-size:10px;color:var(--tdim);margin-bottom:2px;">👁 ${fmtNum(v.view_count||v.views)}${v.like_count ? ' · ❤️ ' + fmtNum(v.like_count) : ''}${v.comment_count ? ' · 💬 ' + fmtNum(v.comment_count) : ''}</div>
        <div style="font-size:9px;color:var(--tmut);">${[v.publish_date?v.publish_date.slice(0,10):'', v.duration_human||v.duration].filter(x=>x&&x!=='NA').join(' · ')}</div>
        ${v.url ? `<a href="${v.url}" target="_blank" style="font-size:9px;color:var(--yd);text-decoration:none;font-family:'Space Mono',monospace;">↗ Open</a>` : ''}
      </div>
    </div>
  `).join('') + `<div style="padding:10px;text-align:right;"><button onclick="exportScrapeJSON()" style="background:var(--s3);border:1px solid var(--bd);border-radius:6px;color:var(--tdim);font-size:10px;padding:6px 10px;cursor:pointer;font-family:'Space Mono',monospace;">⬇ Export JSON</button></div>`;
  window._lastScrapeData = videos;
  document.getElementById('scrapDlBtn').style.display = 'block';
}

function fmtNum(n) {
  if (!n && n !== 0) return '—';
  if (n >= 1000000) return (n/1000000).toFixed(1) + 'M';
  if (n >= 1000) return (n/1000).toFixed(1) + 'K';
  return String(n);
}

function exportScrapeJSON() {
  const blob = new Blob([JSON.stringify(window._lastScrapeData, null, 2)], { type: 'application/json' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'scraped_videos.json'; a.click();
}

</script>
</body>
</html>
