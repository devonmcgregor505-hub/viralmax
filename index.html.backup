<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DubShorts Studio</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --y:#f5e132;--yd:#c8b820;--yg:rgba(245,225,50,0.08);
  --blk:#080808;--s1:#111;--s2:#161616;--s3:#1e1e1e;--s4:#252525;
  --bd:#2a2a2a;--tx:#efefef;--tdim:#888;--tmut:#444;
  --grn:#2ecc71;--red:#ff4136;--pur:#a78bfa;--purg:rgba(167,139,250,0.08);
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;}
body{font-family:'DM Sans',sans-serif;background:var(--blk);color:var(--tx);display:flex;overflow:hidden;}

.sidebar{width:195px;height:100vh;background:var(--s1);border-right:1px solid var(--bd);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;}
.logo{padding:16px 15px 13px;border-bottom:1px solid var(--bd);position:sticky;top:0;background:var(--s1);}
.logo-mark{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;color:var(--y);}
.logo-sub{font-size:8px;color:var(--tmut);margin-top:2px;letter-spacing:2.5px;text-transform:uppercase;}
.nav{padding:8px 7px;flex:1;overflow-y:auto;}
.nav-sec{margin:12px 0;}
.nav-sec:first-child{margin-top:0;}
.nav-seclbl{font-size:7px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--tmut);padding:0 8px;margin:8px 0 3px;}
.ni{display:flex;align-items:center;gap:8px;padding:7px 9px;border-radius:7px;font-size:12px;font-weight:500;color:var(--tdim);transition:all .15s;border:1px solid transparent;margin-bottom:1px;cursor:pointer;background:none;width:100%;text-align:left;}
.ni:hover{background:var(--s2);color:var(--tx);}
.ni.active{background:var(--yg);border-color:rgba(245,225,50,0.18);color:var(--y);}
.ni .ic{font-size:13px;width:15px;text-align:center;flex-shrink:0;}
.badge{margin-left:auto;font-size:8px;padding:2px 4px;border-radius:3px;font-weight:700;}
.badge.live{background:rgba(46,204,113,.1);color:var(--grn);}
.badge.new{background:rgba(245,225,50,.1);color:var(--yd);}
.sf{padding:10px 13px;border-top:1px solid var(--bd);background:var(--s1);}
.credits-display{font-size:11px;color:var(--y);font-weight:700;font-family:'Space Mono',monospace;}

.main{flex:1;display:flex;flex-direction:column;min-width:0;height:100vh;overflow:hidden;}
.topbar{padding:11px 20px;border-bottom:1px solid var(--bd);display:flex;align-items:center;gap:6px;flex-shrink:0;}
.pg-title{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;color:var(--y);}
.pg-sep,.pg-sub{font-size:12px;color:var(--tdim);}
.tab-panel{display:none;flex:1;overflow:hidden;}
.tab-panel.active{display:flex;}

.workspace{flex:1;display:flex;overflow:hidden;}
.left-panel{width:400px;flex-shrink:0;border-right:1px solid var(--bd);overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:11px;}
.right-panel{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;background:var(--blk);gap:10px;padding:20px;overflow-y:auto;}

.sec-lbl{font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--tdim);margin-bottom:6px;}
.upload-zone{border:1.5px dashed var(--bd);border-radius:11px;padding:18px 16px;text-align:center;cursor:pointer;position:relative;transition:all .2s;background:var(--s1);}
.upload-zone:hover{border-color:var(--yd);background:var(--s2);}
.upload-zone.has-file{border-color:rgba(245,225,50,.35);border-style:solid;background:rgba(245,225,50,.02);}
.upload-zone.drag{border-color:var(--y);background:var(--yg);}
.up-icon{font-size:22px;display:block;margin-bottom:5px;}
.up-title{font-size:13px;font-weight:600;margin-bottom:2px;}
.up-hint{font-size:11px;color:var(--tmut);}
.up-name{font-size:10px;color:var(--y);font-weight:600;margin-top:4px;word-break:break-all;}

.text-input{background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:10px 12px;color:var(--tx);font-size:12px;font-family:'DM Sans',sans-serif;width:100%;outline:none;transition:border-color .15s;}
.text-input:focus{border-color:rgba(245,225,50,.4);}
.text-input::placeholder{color:var(--tmut);}

.textarea{background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:10px 12px;color:var(--tx);font-size:12px;font-family:'DM Sans',sans-serif;width:100%;outline:none;resize:vertical;min-height:80px;transition:border-color .15s;}
.textarea:focus{border-color:rgba(245,225,50,.4);}
.textarea::placeholder{color:var(--tmut);}

.btn{padding:12px;background:var(--y);color:var(--blk);border:none;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer;font-family:'Space Mono',monospace;transition:all .2s;width:100%;letter-spacing:.4px;}
.btn:hover{background:#ffe600;box-shadow:0 4px 20px rgba(245,225,50,.2);}
.btn:disabled{background:var(--s4);color:var(--tmut);cursor:not-allowed;box-shadow:none;}

.select{background:var(--s3);border:1px solid var(--bd);color:var(--tx);padding:10px 12px;border-radius:8px;font-size:12px;font-family:'DM Sans',sans-serif;outline:none;cursor:pointer;width:100%;transition:all .15s;}
.select:hover{border-color:rgba(245,225,50,.3);}
.select:focus{border-color:rgba(245,225,50,.5);}

.card{background:var(--s2);border:1px solid var(--bd);border-radius:10px;overflow:hidden;}
.card-hd{padding:9px 12px;border-bottom:1px solid var(--bd);font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--y);}
.card-body{padding:12px;display:flex;flex-direction:column;gap:10px;}

.setting-row{display:flex;flex-direction:column;gap:6px;}
.setting-label{font-size:11px;font-weight:600;color:var(--tdim);}
.setting-value{font-size:10px;color:var(--y);font-family:'Space Mono',monospace;}

.slider-row{display:flex;flex-direction:column;gap:4px;}
.slider{width:100%;cursor:pointer;}
.slider-labels{display:flex;justify-content:space-between;font-size:9px;color:var(--tdim);}

.char-count{font-size:9px;color:var(--tmut);margin-top:4px;}

.prog-wrap{display:none;}
.prog-wrap.vis{display:block;}
.prog-lbl{font-size:10px;color:var(--tdim);font-family:'Space Mono',monospace;margin-bottom:4px;display:flex;justify-content:space-between;}
.prog-track{background:var(--s4);border-radius:4px;height:4px;overflow:hidden;border:1px solid var(--bd);}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--y),#ffe600);border-radius:4px;width:0%;transition:width .35s ease;}

.err-box{background:rgba(255,65,54,.04);border:1px solid rgba(255,65,54,.14);border-radius:9px;padding:11px;display:none;}
.err-box.vis{display:block;}
.err-ttl{font-size:10px;font-weight:700;font-family:'Space Mono',monospace;color:var(--red);margin-bottom:4px;}
.err-msg{color:#ff7070;font-size:11px;line-height:1.5;}

.phone-wrap{height:calc(100vh - 44px - 80px);max-height:560px;aspect-ratio:9/16;max-width:315px;position:relative;border-radius:14px;overflow:hidden;background:#000;border:1.5px solid var(--bd);box-shadow:0 16px 48px rgba(0,0,0,.7);flex-shrink:0;}
.ph-empty{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--tmut);}
.ph-empty span{font-size:28px;}
.ph-empty p{font-size:11px;}
.ph-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:none;}
.prev-lbl{font-size:9px;color:var(--tdim);font-family:'Space Mono',monospace;letter-spacing:1px;}

.result-btns{width:100%;max-width:315px;display:none;flex-direction:column;gap:7px;}
.result-btns.vis{display:flex;}
.dl-btn{display:block;width:100%;padding:9px;background:var(--grn);color:#000;border:none;border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Space Mono',monospace;text-align:center;text-decoration:none;transition:all .2s;}
.dl-btn:hover{background:#27ae60;}

.voice-library{background:var(--s3);border:1px solid var(--bd);border-radius:8px;padding:10px;margin-top:8px;max-height:120px;overflow-y:auto;}
.voice-item{padding:8px;border-bottom:1px solid var(--bd);font-size:11px;}
.voice-item:last-child{border-bottom:none;}
.voice-name{color:var(--tx);font-weight:600;}
.voice-id{color:var(--tdim);font-size:9px;font-family:'Space Mono',monospace;}

.info-box{background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:11px 13px;font-size:11px;color:var(--tdim);line-height:1.8;}
.info-box b{color:var(--tx);}
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="logo">
    <div class="logo-mark">DubShorts</div>
    <div class="logo-sub">AI Studio v3</div>
  </div>
  <nav class="nav">
    <div class="nav-sec">
      <div class="nav-seclbl">Generation</div>
      <button class="ni active" id="nav-vidgen" onclick="switchTab('vidgen')"><span class="ic">✨</span>AI Video Gen<span class="badge live">LIVE</span></button>
      <button class="ni" id="nav-imggen" onclick="switchTab('imggen')"><span class="ic">🎨</span>AI Image Gen<span class="badge live">LIVE</span></button>
    </div>

    <div class="nav-sec">
      <div class="nav-seclbl">Utilities</div>
      <button class="ni" id="nav-voicegen" onclick="switchTab('voicegen')"><span class="ic">🔊</span>Voice Gen<span class="badge live">LIVE</span></button>
      <button class="ni" id="nav-upscale" onclick="switchTab('upscale')"><span class="ic">📈</span>Video Upscaler<span class="badge live">LIVE</span></button>
      <button class="ni" id="nav-deadspace" onclick="switchTab('deadspace')"><span class="ic">🎬</span>Dead Space Remover<span class="badge live">LIVE</span></button>
    </div>

    <div class="nav-sec">
      <div class="nav-seclbl">Content</div>
      <button class="ni" id="nav-scraper" onclick="switchTab('scraper')"><span class="ic">🎥</span>YT Scraper<span class="badge new">NEW</span></button>
      <button class="ni" id="nav-repurpose" onclick="switchTab('repurpose')"><span class="ic">🔄</span>Repurpose<span class="badge new">NEW</span></button>
    </div>
  </nav>
  <div class="sf">
    <div class="credits-display">💳 <span id="creditsDisplay">500 Credits</span></div>
  </div>
</aside>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <span class="pg-title" id="topTitle">AI Video Gen</span>
    <span style="color:var(--tdim); margin-left: auto; font-size: 11px; font-family: 'Space Mono', monospace;">1 credit = $0.01</span>
  </div>

  <!-- ══ AI VIDEO GEN ══ -->
  <div class="tab-panel active" id="tab-vidgen">
    <div class="workspace">
      <div class="left-panel">
        <div class="upload-zone" id="imgDrop" onclick="document.getElementById('imgInput').click()">
          <input type="file" id="imgInput" accept="image/*" style="display:none">
          <span class="up-icon">🖼</span>
          <div class="up-title">Drop image here</div>
          <div class="up-hint">PNG · JPG · WEBP</div>
          <div class="up-name" id="imgFnm"></div>
        </div>

        <div>
          <div class="sec-lbl">Prompt</div>
          <textarea class="textarea" id="aivgPrompt" rows="3" placeholder="Describe the motion…"></textarea>
        </div>

        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Model</label>
              <select class="select" id="vidModel" onchange="updateVidSettings()">
                <option value="veo3-fast" data-cr="60">Veo 3.1 Fast</option>
                <option value="grok" data-cr="30">Grok Imagine</option>
                <option value="sora2" data-cr="35">Sora 2</option>
                <option value="kling26" data-cr="20">Kling 2.6</option>
                <option value="seedance" data-cr="50">Seedance</option>
              </select>
            </div>

            <div class="setting-row">
              <label class="setting-label">Duration</label>
              <select class="select" id="vidDuration">
                <option value="6">6 seconds</option>
                <option value="8" selected>8 seconds</option>
                <option value="10">10 seconds</option>
                <option value="15">15 seconds</option>
              </select>
            </div>

            <div class="setting-row">
              <label class="setting-label">Aspect Ratio</label>
              <select class="select" id="vidAspect">
                <option value="9:16" selected>9:16 (Vertical)</option>
                <option value="16:9">16:9 (Horizontal)</option>
              </select>
            </div>

            <div class="setting-row">
              <label class="setting-label">Cost</label>
              <div class="setting-value" id="vidCost">60 credits</div>
            </div>
          </div>
        </div>

        <button class="btn" id="vidBtn" onclick="startVidGen()">⚡ Generate Video</button>
        <div class="prog-wrap" id="vidProg">
          <div class="prog-lbl"><span id="vpLbl">Initializing...</span><span id="vpPct">0%</span></div>
          <div class="prog-track"><div class="prog-fill" id="vpFill"></div></div>
        </div>
        <div class="err-box" id="vidErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="vidErrMsg"></div></div>
      </div>

      <div class="right-panel">
        <div class="phone-wrap">
          <div class="ph-empty" id="vidEmpty"><span>📱</span><p>Upload an image to begin</p></div>
          <video class="ph-video" id="vidVideo" controls playsinline loop></video>
        </div>
        <div class="prev-lbl">PREVIEW</div>
        <div class="result-btns" id="vidResultBtns">
          <a class="dl-btn" id="vidDlBtn" href="#" download="video.mp4">⬇ Download Video</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ AI IMAGE GEN ══ -->
  <div class="tab-panel" id="tab-imggen">
    <div class="workspace">
      <div class="left-panel">
        <div class="upload-zone" id="refImgDrop" onclick="document.getElementById('refImgInput').click()" style="max-height:200px;">
          <input type="file" id="refImgInput" accept="image/*" style="display:none">
          <span class="up-icon">📷</span>
          <div class="up-title">Reference Image (Optional)</div>
          <div class="up-hint">Drop or click</div>
          <div class="up-name" id="refImgFnm"></div>
        </div>

        <div>
          <div class="sec-lbl">Prompt</div>
          <textarea class="textarea" id="imgPrompt" rows="4" placeholder="Describe the image…"></textarea>
        </div>

        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Model</label>
              <select class="select" id="imgModel" onchange="updateImgCost()">
                <option value="nano-2" data-cr="12">Nano Banana 2</option>
                <option value="nano-pro" data-cr="18">Nano Banana Pro</option>
                <option value="seedream45" data-cr="6">Seedream 4.5</option>
                <option value="seedream50" data-cr="5">Seedream 5.0</option>
              </select>
            </div>

            <div class="setting-row">
              <label class="setting-label">Aspect Ratio</label>
              <select class="select" id="imgAspect">
                <option value="9:16" selected>9:16 (Vertical)</option>
                <option value="16:9">16:9 (Horizontal)</option>
              </select>
            </div>

            <div class="setting-row">
              <label class="setting-label">Cost</label>
              <div class="setting-value" id="imgCost">12 credits</div>
            </div>
          </div>
        </div>

        <button class="btn" id="imgBtn" onclick="startImgGen()">🎨 Generate Image</button>
        <div class="prog-wrap" id="imgProg">
          <div class="prog-lbl"><span id="ipLbl">Generating...</span><span id="ipPct">0%</span></div>
          <div class="prog-track"><div class="prog-fill" id="ipFill"></div></div>
        </div>
        <div class="err-box" id="imgErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="imgErrMsg"></div></div>
      </div>

      <div class="right-panel">
        <div style="width:100%;max-width:400px;aspect-ratio:1;border-radius:12px;background:var(--s3);border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;overflow:hidden;">
          <img id="genImgPrev" style="width:100%;height:100%;object-fit:cover;display:none;" alt="Generated image">
          <div id="imgEmpty" style="text-align:center;color:var(--tdim);">
            <span style="font-size:32px;display:block;margin-bottom:8px;">🎨</span>
            <p style="font-size:11px;">Your generated image will appear here</p>
          </div>
        </div>
        <a class="dl-btn" id="dlImgBtn" href="#" download="image.png" style="display:none;max-width:400px;">⬇ Download Image</a>
      </div>
    </div>
  </div>

  <!-- ══ VOICE GEN ══ -->
  <div class="tab-panel" id="tab-voicegen">
    <div class="workspace">
      <div class="left-panel">
        <div>
          <div class="sec-lbl">Voice Script</div>
          <textarea class="textarea" id="voiceScript" rows="6" placeholder="Enter your voiceover script…" onchange="updateCharCount()" oninput="updateCharCount()"></textarea>
          <div class="char-count"><span id="charCount">0</span> / 100,000 characters</div>
        </div>

        <div class="card">
          <div class="card-hd">Voice Selection</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Preset Voice</label>
              <select class="select" id="voicePreset" onchange="selectPresetVoice()">
                <option value="">Select a voice...</option>
                <option value="mark">Mark - UgBBYS2sOqTuMpoF3BR0</option>
                <option value="alex">Alex - yl2ZDV1MzN4HbQJbMihG</option>
                <option value="jessica">Jessica (2) - g6xIsTj2HwM6VR4iXFCw</option>
              </select>
            </div>

            <div style="border-top:1px solid var(--bd);padding-top:10px;margin-top:10px;">
              <label class="setting-label" style="margin-bottom:8px;display:block;">Use Public Voice ID</label>
              <input type="text" class="text-input" id="customVoiceId" placeholder="Enter voice ID" style="font-size:10px;">
              <button class="btn" style="margin-top:8px;padding:8px;font-size:11px;" onclick="saveCustomVoice()">Save Voice</button>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-hd">ElevenLabs Settings</div>
          <div class="card-body">
            <div class="slider-row">
              <label class="setting-label">Speed</label>
              <div class="slider-labels">
                <span>Slower</span>
                <span id="speedVal">0.84</span>
                <span>Faster</span>
              </div>
              <input type="range" class="slider" id="speedSlider" min="0.5" max="2" step="0.1" value="0.84" oninput="updateSpeedVal()">
            </div>

            <div class="slider-row">
              <label class="setting-label">Stability</label>
              <div class="slider-labels">
                <span>Variable</span>
                <span id="stabilityVal">50%</span>
                <span>Stable</span>
              </div>
              <input type="range" class="slider" id="stabilitySlider" min="0" max="100" value="50" oninput="updateStabilityVal()">
            </div>

            <div class="slider-row">
              <label class="setting-label">Similarity</label>
              <div class="slider-labels">
                <span>Low</span>
                <span id="similarityVal">75%</span>
                <span>High</span>
              </div>
              <input type="range" class="slider" id="similaritySlider" min="0" max="100" value="75" oninput="updateSimilarityVal()">
            </div>

            <div class="slider-row">
              <label class="setting-label">Style Exaggeration</label>
              <div class="slider-labels">
                <span>None</span>
                <span id="styleVal">0%</span>
                <span>Exaggerated</span>
              </div>
              <input type="range" class="slider" id="styleSlider" min="0" max="100" value="0" oninput="updateStyleVal()">
            </div>

            <button class="btn" style="margin-top:10px;padding:8px;font-size:11px;" onclick="resetVoiceSettings()">Reset Values</button>
          </div>
        </div>

        <button class="btn" id="voiceBtn" onclick="startVoiceGen()">🔊 Generate Speech</button>
        <div class="prog-wrap" id="voiceProg">
          <div class="prog-lbl"><span id="vrLbl">Generating...</span><span id="vrPct">0%</span></div>
          <div class="prog-track"><div class="prog-fill" id="vrFill"></div></div>
        </div>
        <div class="err-box" id="voiceErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="voiceErrMsg"></div></div>
      </div>

      <div class="right-panel">
        <div style="width:100%;max-width:400px;background:var(--s2);border:1px solid var(--bd);border-radius:12px;padding:20px;text-align:center;">
          <div style="font-size:32px;margin-bottom:15px;">🔊</div>
          <audio id="voiceAudio" controls style="width:100%;display:none;"></audio>
          <div id="voiceEmpty" style="color:var(--tdim);font-size:12px;">Your generated speech will appear here</div>
          <a class="dl-btn" id="dlVoiceBtn" href="#" download="speech.mp3" style="display:none;margin-top:15px;">⬇ Download Audio</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ VIDEO UPSCALER ══ -->
  <div class="tab-panel" id="tab-upscale">
    <div class="workspace">
      <div class="left-panel">
        <div class="upload-zone" id="upscaleZone" onclick="document.getElementById('upscaleInput').click()">
          <input type="file" id="upscaleInput" accept="video/*" style="display:none">
          <span class="up-icon">📈</span>
          <div class="up-title">Drop video here</div>
          <div class="up-hint">MP4 · MOV</div>
          <div class="up-name" id="upscaleFnm"></div>
        </div>

        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Target Quality</label>
              <select class="select" id="upscaleQuality" onchange="updateUpscaleCost()">
                <option value="1080" data-cr="10">1080p - 10 credits</option>
                <option value="2k" data-cr="20">2K - 20 credits</option>
                <option value="4k" data-cr="40">4K - 40 credits</option>
              </select>
            </div>
            <div class="setting-row">
              <label class="setting-label">Cost</label>
              <div class="setting-value" id="upCost">10 credits</div>
            </div>
          </div>
        </div>

        <button class="btn" id="upscaleBtn" onclick="startUpscale()" disabled>📈 Upscale Video</button>
        <div class="prog-wrap" id="upProg">
          <div class="prog-lbl"><span id="upLbl">Upscaling...</span><span id="upPct">0%</span></div>
          <div class="prog-track"><div class="prog-fill" id="upFill"></div></div>
        </div>
        <div class="err-box" id="upErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="upErrMsg"></div></div>
      </div>

      <div class="right-panel">
        <div class="phone-wrap">
          <div class="ph-empty"><span>📁</span><p>Upload a video to upscale</p></div>
          <video id="upVid" controls style="display:none;position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"></video>
        </div>
        <div class="prev-lbl">UPSCALED</div>
      </div>
    </div>
  </div>

  <!-- ══ DEAD SPACE REMOVER ══ -->
  <div class="tab-panel" id="tab-deadspace">
    <div class="workspace">
      <div class="left-panel">
        <div class="upload-zone" id="deadspaceZone" onclick="document.getElementById('deadspaceInput').click()">
          <input type="file" id="deadspaceInput" accept="video/*,audio/*" style="display:none">
          <span class="up-icon">🎬</span>
          <div class="up-title">Drop video/audio here</div>
          <div class="up-hint">MP4 · MOV · WAV · MP3</div>
          <div class="up-name" id="deadspaceFnm"></div>
        </div>

        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="slider-row">
              <label class="setting-label">Silence Threshold (dB)</label>
              <div class="slider-labels">
                <span>Sensitive</span>
                <span id="dbVal">-40</span>
                <span>Aggressive</span>
              </div>
              <input type="range" class="slider" id="dbSlider" min="-60" max="-10" value="-40" oninput="updateDbVal()">
            </div>
            <div class="setting-row">
              <label class="setting-label">Cost</label>
              <div class="setting-value">5 credits</div>
            </div>
          </div>
        </div>

        <button class="btn" id="dsBtn" onclick="startDeadspace()" disabled>🎬 Remove Dead Space</button>
        <div class="prog-wrap" id="dsProg">
          <div class="prog-lbl"><span id="dsLbl">Processing...</span><span id="dsPct">0%</span></div>
          <div class="prog-track"><div class="prog-fill" id="dsFill"></div></div>
        </div>
        <div class="err-box" id="dsErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="dsErrMsg"></div></div>
      </div>

      <div class="right-panel">
        <div class="phone-wrap">
          <div class="ph-empty"><span>📁</span><p>Upload a video/audio file</p></div>
          <video id="dsVid" controls style="display:none;position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"></video>
        </div>
        <div class="prev-lbl">TRIMMED</div>
      </div>
    </div>
  </div>

  <!-- ══ YT SCRAPER ══ -->
  <div class="tab-panel" id="tab-scraper">
    <div class="workspace">
      <div class="left-panel">
        <div>
          <div class="sec-lbl">Channel Link</div>
          <input type="text" class="text-input" id="ytChannelUrl" placeholder="https://youtube.com/@channelname">
        </div>

        <div class="card">
          <div class="card-hd">Settings</div>
          <div class="card-body">
            <div class="setting-row">
              <label class="setting-label">Number of Videos</label>
              <select class="select" id="ytCount">
                <option value="10">10 videos</option>
                <option value="25" selected>25 videos</option>
                <option value="50">50 videos</option>
                <option value="100">100 videos</option>
              </select>
            </div>

            <div class="setting-row">
              <label class="setting-label">Content Type</label>
              <select class="select" id="ytType">
                <option value="shorts">Shorts</option>
                <option value="longform">Long Form</option>
              </select>
            </div>

            <div class="setting-row">
              <label class="setting-label">Cost</label>
              <div class="setting-value">2 credits</div>
            </div>
          </div>
        </div>

        <button class="btn" id="scrapBtn" onclick="startScrape()">🎥 Scrape Channel</button>
        <div class="prog-wrap" id="scrapProg">
          <div class="prog-lbl"><span id="scLbl">Scraping...</span><span id="scPct">0%</span></div>
          <div class="prog-track"><div class="prog-fill" id="scFill"></div></div>
        </div>
        <div class="err-box" id="scrapErr"><div class="err-ttl">// ERROR</div><div class="err-msg" id="scrapErrMsg"></div></div>
      </div>

      <div class="right-panel">
        <div style="width:100%;max-width:400px;background:var(--s2);border:1px solid var(--bd);border-radius:12px;overflow:hidden;">
          <div style="padding:14px;border-bottom:1px solid var(--bd);font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--y);">Scraped Videos</div>
          <div class="list-wrap" id="scrapList" style="max-height:300px;border:none;border-radius:0;overflow-y:auto;padding:10px;">
            <div style="text-align:center;padding:30px;color:var(--tdim);font-size:11px;">No data yet</div>
          </div>
          <a href="#" id="exportBtn" class="dl-btn" style="display:none;border-radius:0;margin:0;">⬇ Export as CSV</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ REPURPOSE & DISTRIBUTE ══ -->
  <div class="tab-panel" id="tab-repurpose">
    <div class="workspace">
      <div class="left-panel">
        <div>
          <div class="sec-lbl">YouTube Channel Link</div>
          <input type="text" class="text-input" id="repYtChannel" placeholder="https://youtube.com/@yourchannel">
        </div>

        <div class="card">
          <div class="card-hd">Platforms</div>
          <div class="card-body">
            <label style="display:flex;gap:8px;align-items:center;font-size:12px;cursor:pointer;margin-bottom:8px;">
              <input type="checkbox" id="repTiktok" checked> TikTok
            </label>
            <label style="display:flex;gap:8px;align-items:center;font-size:12px;cursor:pointer;">
              <input type="checkbox" id="repInstagram" checked> Instagram
            </label>
          </div>
        </div>

        <div class="card">
          <div class="card-hd">Account Connections</div>
          <div class="card-body">
            <div id="tiktokConnect" style="display:none;">
              <button class="btn" style="padding:10px;font-size:11px;margin-bottom:8px;" onclick="connectTiktok()">Connect TikTok Account</button>
              <div id="tiktokStatus" style="font-size:10px;color:var(--tdim);text-align:center;">Not connected</div>
            </div>
            <div id="instagramConnect" style="display:none;">
              <button class="btn" style="padding:10px;font-size:11px;" onclick="connectInstagram()">Connect Instagram Account</button>
              <div id="instagramStatus" style="font-size:10px;color:var(--tdim);text-align:center;">Not connected</div>
            </div>
          </div>
        </div>

        <button class="btn" id="repBtn" onclick="startRepurpose()">🔄 Enable Auto-Repurpose</button>
        <div class="info-box" style="margin-top:10px;">
          <b>How it works</b><br>
          1. Monitor your YT uploads<br>
          2. Auto-detect new videos<br>
          3. Download & optimize<br>
          4. Repost to platforms
        </div>
      </div>

      <div class="right-panel">
        <div style="width:100%;max-width:400px;text-align:center;padding:40px 20px;color:var(--tdim);">
          <span style="font-size:32px;display:block;margin-bottom:10px;">🔄</span>
          <p style="font-size:12px;">Connect your accounts and enable auto-repurposing</p>
          <div id="repStatus" style="margin-top:20px;font-size:11px;color:var(--tmut);">Status: Inactive</div>
        </div>
      </div>
    </div>
  </div>

</div>

<script src="https://js.puter.com/v2/"></script>
<script>
// ══ STATE ══
let credentials = { credits: 500, voiceId: null };
let selectedVoices = {};

// ══ TAB SWITCHING ══
function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.ni').forEach(n => n.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  document.getElementById('nav-' + tab).classList.add('active');
  
  const titles = {
    vidgen: 'AI Video Gen',
    imggen: 'AI Image Gen',
    voicegen: 'Voice Gen',
    upscale: 'Video Upscaler',
    deadspace: 'Dead Space Remover',
    scraper: 'YT Scraper',
    repurpose: 'Repurpose & Distribute',
  };
  document.getElementById('topTitle').textContent = titles[tab] || 'DubShorts';
}

// ══ CREDITS ══
function updateCreditsDisplay() {
  document.getElementById('creditsDisplay').textContent = credentials.credits + ' Credits';
}

// ══ VIDEO GEN ══
const imgDrop = document.getElementById('imgDrop'), imgInput = document.getElementById('imgInput');
imgDrop.addEventListener('dragover', e => { e.preventDefault(); imgDrop.classList.add('drag'); });
imgDrop.addEventListener('dragleave', () => imgDrop.classList.remove('drag'));
imgDrop.addEventListener('drop', e => {
  e.preventDefault(); imgDrop.classList.remove('drag');
  const f = e.dataTransfer.files[0];
  if(f && f.type.startsWith('image/')) {
    imgInput.files = new DataTransfer().items.add(f).transfer.files;
    loadImg(f);
  }
});
imgInput.addEventListener('change', () => { if(imgInput.files[0]) loadImg(imgInput.files[0]); });

function loadImg(f) {
  document.getElementById('imgFnm').textContent = '📎 ' + f.name;
  imgDrop.classList.add('has-file');
  document.getElementById('vidEmpty').style.display = 'none';
}

function updateVidSettings() {
  const model = document.getElementById('vidModel').value;
  const costs = { 'veo3-fast': 60, 'grok': 30, 'sora2': 35, 'kling26': 20, 'seedance': 50 };
  document.getElementById('vidCost').textContent = costs[model] + ' credits';
}

function startVidGen() {
  const f = imgInput.files[0];
  if(!f) { alert('Please upload an image.'); return; }
  const script = document.getElementById('aivgPrompt').value.trim();
  if(!script) { alert('Please enter a prompt.'); return; }
  alert('✓ Video generation started!');
}

// ══ IMAGE GEN ══
const refImgDrop = document.getElementById('refImgDrop'), refImgInput = document.getElementById('refImgInput');
refImgDrop.addEventListener('click', () => refImgInput.click());
refImgDrop.addEventListener('dragover', e => { e.preventDefault(); refImgDrop.classList.add('drag'); });
refImgDrop.addEventListener('dragleave', () => refImgDrop.classList.remove('drag'));
refImgDrop.addEventListener('drop', e => {
  e.preventDefault(); refImgDrop.classList.remove('drag');
  const f = e.dataTransfer.files[0];
  if(f) loadRefImg(f);
});
refImgInput.addEventListener('change', () => { if(refImgInput.files[0]) loadRefImg(refImgInput.files[0]); });

function loadRefImg(f) {
  document.getElementById('refImgFnm').textContent = '📎 ' + f.name;
  refImgDrop.classList.add('has-file');
}

function updateImgCost() {
  const model = document.getElementById('imgModel').value;
  const costs = { 'nano-2': 12, 'nano-pro': 18, 'seedream45': 6, 'seedream50': 5 };
  document.getElementById('imgCost').textContent = costs[model] + ' credits';
}

function startImgGen() {
  const prompt = document.getElementById('imgPrompt').value.trim();
  if(!prompt) { alert('Please enter a prompt.'); return; }
  alert('✓ Image generation started!');
}

// ══ VOICE GEN ══
function updateCharCount() {
  const text = document.getElementById('voiceScript').value;
  document.getElementById('charCount').textContent = text.length;
}

function selectPresetVoice() {
  const val = document.getElementById('voicePreset').value;
  if(val === 'mark') credentials.voiceId = 'UgBBYS2sOqTuMpoF3BR0';
  else if(val === 'alex') credentials.voiceId = 'yl2ZDV1MzN4HbQJbMihG';
  else if(val === 'jessica') credentials.voiceId = 'g6xIsTj2HwM6VR4iXFCw';
}

function saveCustomVoice() {
  const id = document.getElementById('customVoiceId').value.trim();
  if(!id) { alert('Please enter a voice ID.'); return; }
  credentials.voiceId = id;
  alert('✓ Voice ID saved!');
}

function updateSpeedVal() { document.getElementById('speedVal').textContent = document.getElementById('speedSlider').value; }
function updateStabilityVal() { document.getElementById('stabilityVal').textContent = document.getElementById('stabilitySlider').value + '%'; }
function updateSimilarityVal() { document.getElementById('similarityVal').textContent = document.getElementById('similaritySlider').value + '%'; }
function updateStyleVal() { document.getElementById('styleVal').textContent = document.getElementById('styleSlider').value + '%'; }

function resetVoiceSettings() {
  document.getElementById('speedSlider').value = 0.84;
  document.getElementById('stabilitySlider').value = 50;
  document.getElementById('similaritySlider').value = 75;
  document.getElementById('styleSlider').value = 0;
  updateSpeedVal(); updateStabilityVal(); updateSimilarityVal(); updateStyleVal();
}

async function startVoiceGen() {
  const script = document.getElementById('voiceScript').value.trim();
  if(!script) { alert('Please enter a script.'); return; }
  if(!credentials.voiceId) { alert('Please select a voice.'); return; }
  
  document.getElementById('voiceBtn').disabled = true;
  document.getElementById('voiceProg').classList.add('vis');
  
  try {
    const audio = await puter.ai.txt2speech(script, {
      provider: 'elevenlabs',
      voice: credentials.voiceId,
      model: 'eleven_multilingual_v2'
    });
    
    document.getElementById('voiceAudio').src = URL.createObjectURL(audio);
    document.getElementById('voiceAudio').style.display = 'block';
    document.getElementById('voiceEmpty').style.display = 'none';
    document.getElementById('dlVoiceBtn').style.display = 'block';
    
  } catch(err) {
    alert('Error: ' + err.message);
  }
  
  document.getElementById('voiceProg').classList.remove('vis');
  document.getElementById('voiceBtn').disabled = false;
}

// ══ VIDEO UPSCALER ══
const upscaleZone = document.getElementById('upscaleZone'), upscaleInput = document.getElementById('upscaleInput');
upscaleZone.addEventListener('click', () => upscaleInput.click());
upscaleZone.addEventListener('dragover', e => { e.preventDefault(); upscaleZone.classList.add('drag'); });
upscaleZone.addEventListener('dragleave', () => upscaleZone.classList.remove('drag'));
upscaleZone.addEventListener('drop', e => {
  e.preventDefault(); upscaleZone.classList.remove('drag');
  const f = e.dataTransfer.files[0];
  if(f) loadUpscale(f);
});
upscaleInput.addEventListener('change', () => { if(upscaleInput.files[0]) loadUpscale(upscaleInput.files[0]); });

function loadUpscale(f) {
  document.getElementById('upscaleFnm').textContent = '📎 ' + f.name;
  upscaleZone.classList.add('has-file');
  document.getElementById('upscaleBtn').disabled = false;
  document.getElementById('upVid').src = URL.createObjectURL(f);
  document.getElementById('upVid').style.display = 'block';
}

function updateUpscaleCost() {
  const sel = document.getElementById('upscaleQuality');
  const cost = sel.options[sel.selectedIndex].dataset.cr;
  document.getElementById('upCost').textContent = cost + ' credits';
}

function startUpscale() {
  alert('✓ Upscaling started!');
}

// ══ DEAD SPACE REMOVER ══
const deadspaceZone = document.getElementById('deadspaceZone'), deadspaceInput = document.getElementById('deadspaceInput');
deadspaceZone.addEventListener('click', () => deadspaceInput.click());
deadspaceZone.addEventListener('dragover', e => { e.preventDefault(); deadspaceZone.classList.add('drag'); });
deadspaceZone.addEventListener('dragleave', () => deadspaceZone.classList.remove('drag'));
deadspaceZone.addEventListener('drop', e => {
  e.preventDefault(); deadspaceZone.classList.remove('drag');
  const f = e.dataTransfer.files[0];
  if(f) loadDeadspace(f);
});
deadspaceInput.addEventListener('change', () => { if(deadspaceInput.files[0]) loadDeadspace(deadspaceInput.files[0]); });

function loadDeadspace(f) {
  document.getElementById('deadspaceFnm').textContent = '📎 ' + f.name;
  deadspaceZone.classList.add('has-file');
  document.getElementById('dsBtn').disabled = false;
  document.getElementById('dsVid').src = URL.createObjectURL(f);
  document.getElementById('dsVid').style.display = 'block';
}

function updateDbVal() {
  document.getElementById('dbVal').textContent = document.getElementById('dbSlider').value;
}

function startDeadspace() {
  alert('✓ Processing started!');
}

// ══ YT SCRAPER ══
function startScrape() {
  const url = document.getElementById('ytChannelUrl').value.trim();
  if(!url) { alert('Please enter a channel URL.'); return; }
  alert('✓ Scraping started!');
}

// ══ REPURPOSE ══
function connectTiktok() {
  alert('✓ TikTok connection would open OAuth flow');
  document.getElementById('tiktokStatus').textContent = 'Connected ✓';
}

function connectInstagram() {
  alert('✓ Instagram connection would open OAuth flow');
  document.getElementById('instagramStatus').textContent = 'Connected ✓';
}

function startRepurpose() {
  const yt = document.getElementById('repYtChannel').value.trim();
  if(!yt) { alert('Please enter your YT channel link.'); return; }
  
  const tiktok = document.getElementById('repTiktok').checked;
  const instagram = document.getElementById('repInstagram').checked;
  
  if(!tiktok && !instagram) { alert('Select at least one platform.'); return; }
  
  if(tiktok) connectTiktok();
  if(instagram) connectInstagram();
  
  document.getElementById('repStatus').textContent = 'Status: Active ✓';
}

// ══ INIT ══
updateCreditsDisplay();
updateVidSettings();
updateImgCost();

// Show/hide platform connections
document.getElementById('repTiktok').addEventListener('change', () => {
  document.getElementById('tiktokConnect').style.display = document.getElementById('repTiktok').checked ? 'block' : 'none';
});
document.getElementById('repInstagram').addEventListener('change', () => {
  document.getElementById('instagramConnect').style.display = document.getElementById('repInstagram').checked ? 'block' : 'none';
});

// Trigger on load
document.getElementById('repTiktok').dispatchEvent(new Event('change'));
document.getElementById('repInstagram').dispatchEvent(new Event('change'));
</script>
</body>
</html>
